---
/*
文件说明: 为公开工具页提供统一的顶层工具 Tab，方便在多个工具之间快速切换。
*/
type ToolTabKey = 'session-converter' | 'ip-purity';

type ToolTab = {
  key: ToolTabKey;
  label: string;
  href: string;
  badge?: string;
};

type Props = {
  activeTab?: ToolTabKey;
};

const { activeTab } = Astro.props;
const t = Astro.locals.messages;
const linkTo = Astro.locals.localizePath;
const tabs: ToolTab[] = [
  {
    key: 'session-converter',
    label: t.tools.sessionConverter.tabLabel,
    href: '/tools/session-converter',
    badge: t.labels.localConvert,
  },
  {
    key: 'ip-purity',
    label: t.nav.ipPurity,
    href: '/tools/ip-purity',
    badge: 'IPv4',
  },
];
---

<section class="card bg-base-100 border border-base-300 shadow-sm">
  <div class="card-body p-4">
    <div class="tool-tablist-wrap">
      <div role="tablist" class="tabs tabs-box" aria-label={t.nav.tools}>
        {tabs.map((tab) => {
          const isActive = tab.key === activeTab;
          return (
            <a
              role="tab"
              href={linkTo(tab.href)}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'tab',
                isActive && 'tab-active',
              ]}
            >
              <span>{tab.label}</span>
              {tab.badge && <span class="tool-tab-badge">{tab.badge}</span>}
            </a>
          );
        })}
      </div>
    </div>
  </div>
</section>
