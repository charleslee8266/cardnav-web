---
/*
文件说明: 渲染模型排行榜页的服务端 HTML 内容，包括任务导航和当前任务榜单。
*/
import type { LocalizedModelLeaderboardGroup } from '../localized-display.js';

type Props = {
  groups: LocalizedModelLeaderboardGroup[];
  currentGroup: LocalizedModelLeaderboardGroup | null;
  updateTime: string;
};

const { groups, currentGroup, updateTime } = Astro.props;
const t = Astro.locals.messages;
const linkTo = Astro.locals.localizePath;
const initialRowCount = 30;
const visibleRows = currentGroup?.rows.slice(0, initialRowCount) ?? [];
const deferredRows = currentGroup?.rows.slice(initialRowCount).map(row => ({
  rank: row.rank,
  modelName: row.modelName,
  score: row.score,
})) ?? [];
const deferredRowsJson = JSON.stringify(deferredRows).replace(/[<>&\u2028\u2029]/g, character => ({
  '<': '\\u003C',
  '>': '\\u003E',
  '&': '\\u0026',
  '\u2028': '\\u2028',
  '\u2029': '\\u2029',
}[character] || character));
---

<section class="card bg-base-100 border border-base-300 shadow-sm">
  <div class="card-body p-5">
    <div class="page-hero-wrap">
      <h1 class="page-hero-title">
        {currentGroup ? `${currentGroup.displayName}${t.leaderboard.titleSuffix}` : t.leaderboard.title}
      </h1>
      <p class="page-hero-copy">
        {t.leaderboard.description}
      </p>
    </div>
    <div class="flex flex-wrap items-center gap-3 text-xs text-base-content/60">
      <span>{t.labels.latestRefreshBeijing}：{updateTime}</span>
    </div>
  </div>
</section>

{groups.length > 0 && (
  <nav class="tabs tabs-box w-fit max-w-full flex-wrap" aria-label={t.leaderboard.taskNavLabel}>
    {groups.map(group => (
      <a
        role="tab"
        href={linkTo(group.pathname)}
        class={'tab text-sm ' + (currentGroup?.taskSlug === group.taskSlug ? 'tab-active font-semibold text-primary' : 'text-base-content/70 hover:text-base-content')}
        aria-current={currentGroup?.taskSlug === group.taskSlug ? 'page' : undefined}
      >
        {group.displayName}
      </a>
    ))}
  </nav>
)}

{currentGroup && (
  <section class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden" data-model-leaderboard>
    <div class="bg-base-200/50 px-4 py-3 border-b border-base-300">
      <p class="text-sm font-bold text-base-content">{currentGroup.displayName}</p>
    </div>
    <div class="product-table-scroll">
      <table class="table table-zebra table-md w-full border-collapse">
        <thead class="bg-base-200 text-base-content text-sm">
          <tr>
            <th scope="col" class="font-bold">{t.labels.rank}</th>
            <th scope="col" class="font-bold">{t.labels.model}</th>
            <th scope="col" class="font-bold text-primary">{t.labels.score}</th>
          </tr>
        </thead>
        <tbody data-model-leaderboard-body>
          {visibleRows.map(item => (
            <tr class="hover">
              <td class="font-bold">
                {item.rank <= 3 ? '#' + item.rank : item.rank}
              </td>
              <td class="font-semibold text-base-content break-all">{item.modelName}</td>
              <td class="font-mono font-bold text-primary">{item.score.toFixed(2)}</td>
            </tr>
          ))}
          {currentGroup.rows.length === 0 && (
            <tr>
              <td colspan="3" class="p-8 text-center text-base-content/40">{t.leaderboard.empty}</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
    {deferredRows.length > 0 ? (
      <div class="border-t border-base-300 p-4 text-center">
        <button type="button" class="btn btn-outline btn-sm" data-model-leaderboard-load-more>{t.leaderboard.loadMore}</button>
      </div>
    ) : null}
    <script is:inline type="application/json" data-model-leaderboard-deferred set:html={deferredRowsJson}></script>
  </section>
)}

{groups.length === 0 && (
  <section class="alert alert-info alert-soft max-w-md mx-auto my-6 justify-center">
    <span>{t.leaderboard.empty}</span>
  </section>
)}

<script is:inline>
  document.querySelectorAll('[data-model-leaderboard]').forEach(leaderboard => {
    const button = leaderboard.querySelector('[data-model-leaderboard-load-more]');
    if (!button) return;

    const escapeHtml = value => String(value ?? '').replace(/[&<>"']/g, character => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    }[character]));
    const deferredRows = JSON.parse(leaderboard.querySelector('[data-model-leaderboard-deferred]')?.textContent || '[]');
    const rowHtml = item => {
      const rank = Number(item.rank);
      const score = Number(item.score);
      return `<tr class="hover">
        <td class="font-bold">${rank <= 3 ? `#${rank}` : rank}</td>
        <td class="font-semibold text-base-content break-all">${escapeHtml(item.modelName)}</td>
        <td class="font-mono font-bold text-primary">${Number.isFinite(score) ? score.toFixed(2) : '-'}</td>
      </tr>`;
    };

    button.addEventListener('click', () => {
      const body = leaderboard.querySelector('[data-model-leaderboard-body]');
      if (deferredRows.length) body?.insertAdjacentHTML('beforeend', deferredRows.map(rowHtml).join(''));
      button.closest('div')?.remove();
    }, { once: true });
  });
</script>
