---
/*
文件说明: 渲染模型排行榜页的服务端 HTML 内容，包括任务导航和当前任务榜单。
*/
import PageHero from './PageHero.astro';
import type { LocalizedModelLeaderboardGroup } from '../localized-display.js';

type Props = {
  groups: LocalizedModelLeaderboardGroup[];
  currentGroup: LocalizedModelLeaderboardGroup | null;
  updateTime: string;
};

const { groups, currentGroup, updateTime } = Astro.props;
const t = Astro.locals.messages;
const linkTo = Astro.locals.localizePath;
const initialRowCount = 30;
const visibleRows = currentGroup?.rows.slice(0, initialRowCount) ?? [];
const hasMoreRows = (currentGroup?.rows.length ?? 0) > initialRowCount;
const leaderboardApiUrl = currentGroup
  ? `/api/model-leaderboard/${encodeURIComponent(currentGroup.taskSlug)}.json?offset=${initialRowCount}&locale=${encodeURIComponent(Astro.locals.locale)}`
  : '';
---

<PageHero
  title={currentGroup ? `${currentGroup.displayName}${t.leaderboard.titleSuffix}` : t.leaderboard.title}
  description={t.leaderboard.description}
>
  <p slot="meta" class="page-hero-meta">
    <span>{t.labels.latestRefreshBeijing}：{updateTime}</span>
  </p>
</PageHero>

{(groups.length > 0 || currentGroup) && (
  <section
    class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden"
    data-model-leaderboard={currentGroup ? '' : undefined}
    data-model-leaderboard-api={currentGroup ? leaderboardApiUrl : undefined}
  >
    {groups.length > 0 && (
      <div class="border-b border-base-300 bg-base-100 px-4 py-3">
        <nav class="tool-tablist-wrap" aria-label={t.leaderboard.taskNavLabel}>
          <div class="tabs tabs-box content-tablist" role="tablist">
            {groups.map(group => {
              const isCurrent = currentGroup?.taskSlug === group.taskSlug;
              return (
                <a
                  role="tab"
                  href={linkTo(group.pathname)}
                  class={`tab content-tab ${isCurrent ? 'tab-active' : ''}`}
                  aria-selected={isCurrent ? 'true' : 'false'}
                  aria-current={isCurrent ? 'page' : undefined}
                >
                  {group.displayName}
                </a>
              );
            })}
          </div>
        </nav>
      </div>
    )}
    {currentGroup && (
      <>
        <div class="bg-base-200/50 px-4 py-3 border-b border-base-300">
          <p class="text-sm font-bold text-base-content">{currentGroup.displayName}</p>
        </div>
        <div class="product-table-scroll">
          <table class="table table-zebra table-md w-full border-collapse">
            <thead class="bg-base-200 text-base-content text-sm">
              <tr>
                <th scope="col" class="font-bold">{t.labels.rank}</th>
                <th scope="col" class="font-bold">{t.labels.model}</th>
                <th scope="col" class="font-bold text-primary">{t.labels.score}</th>
              </tr>
            </thead>
            <tbody data-model-leaderboard-body>
              {visibleRows.map(item => (
                <tr class="hover">
                  <td class="font-bold">
                    {item.rank <= 3 ? '#' + item.rank : item.rank}
                  </td>
                  <td class="font-semibold text-base-content break-all">{item.modelName}</td>
                  <td class="font-mono font-bold text-primary">{item.score.toFixed(2)}</td>
                </tr>
              ))}
              {currentGroup.rows.length === 0 && (
                <tr>
                  <td colspan="3" class="p-8 text-center text-base-content/40">{t.leaderboard.empty}</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
        {hasMoreRows ? (
          <div class="border-t border-base-300 p-4 text-center">
            <button type="button" class="btn btn-outline btn-sm" data-model-leaderboard-load-more>{t.leaderboard.loadMore}</button>
          </div>
        ) : null}
      </>
    )}
  </section>
)}

{groups.length === 0 && (
  <section class="alert alert-info alert-soft max-w-md mx-auto my-6 justify-center">
    <span>{t.leaderboard.empty}</span>
  </section>
)}
