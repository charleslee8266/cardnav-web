---
/*
文件说明: 渲染官方订阅比价页的服务端 HTML 内容，包括套餐导航和当前套餐价格表。
*/
import PageHero from './PageHero.astro';
import type { LocalizedOfficialPriceGroup } from '../localized-display.js';

type Props = {
  groups: LocalizedOfficialPriceGroup[];
  currentGroup: LocalizedOfficialPriceGroup | null;
  updateTime: string;
};

const { groups, currentGroup, updateTime } = Astro.props;
const t = Astro.locals.messages;
const linkTo = Astro.locals.localizePath;

type CountryFlag = {
  emoji: string;
};

function countryFlag(countryCode: string): CountryFlag {
  const normalized = countryCode.trim().toUpperCase();
  const regionFlags: Record<string, string> = {
    HK: '🇭🇰',
    MO: '🇲🇴',
    TW: '🇨🇳',
  };
  if (regionFlags[normalized]) return { emoji: regionFlags[normalized] };
  if (!/^[A-Z]{2}$/.test(normalized)) return { emoji: '' };
  const emoji = [...normalized]
    .map(char => String.fromCodePoint(0x1F1E6 + char.charCodeAt(0) - 65))
    .join('');
  return { emoji };
}
---

<PageHero
  title={currentGroup ? `${currentGroup.displayName} ${t.officialPrice.titleSuffix}` : t.officialPrice.title}
  description={t.officialPrice.description}
>
  <p slot="note" class="page-hero-note">{t.officialPrice.note}</p>
  {updateTime && (
    <p slot="meta" class="page-hero-meta">
      <span>{t.labels.latestRefreshBeijing}：{updateTime}</span>
    </p>
  )}
</PageHero>

{groups.length > 0 && (
  <nav class="tabs tabs-box w-fit max-w-full flex-wrap" aria-label={t.officialPrice.navLabel}>
    {groups.map(group => (
      <a
        role="tab"
        href={linkTo(group.pathname)}
        class={`tab text-sm ${currentGroup?.key === group.key ? 'tab-active font-semibold text-primary' : 'text-base-content/70 hover:text-base-content'}`}
        aria-current={currentGroup?.key === group.key ? 'page' : undefined}
      >
        {group.displayName}
      </a>
    ))}
  </nav>
)}

{currentGroup && (
  <section class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden">
    <div class="bg-base-200/50 px-4 py-2 text-xs font-semibold text-base-content/60 border-b border-base-300">
      {currentGroup.appName} {currentGroup.planName} {t.officialPrice.tableSummarySuffix}
    </div>
    <div class="product-table-scroll">
      <table class="table table-zebra table-md w-full border-collapse">
        <thead class="bg-base-200 text-base-content text-sm">
          <tr>
            <th scope="col" class="font-bold">{t.officialPrice.recommendedRank}</th>
            <th scope="col" class="font-bold">{t.officialPrice.countryRegion}</th>
            <th scope="col" class="font-bold">{t.officialPrice.localPrice}</th>
            <th scope="col" class="font-bold">{t.officialPrice.currency}</th>
            <th scope="col" class="font-bold text-primary">{t.officialPrice.cnyPrice}</th>
          </tr>
        </thead>
        <tbody>
          {currentGroup.prices.map((item, idx) => {
            const flag = countryFlag(item.countryCode);
            return (
            <tr class="hover">
              <td class="font-bold">
                {idx === 0 ? t.officialPrice.cheapest : idx === 1 || idx === 2 ? t.officialPrice.recommended : `${idx + 1}`}
              </td>
              <td class="font-semibold text-base-content">
                <span class="inline-flex items-center gap-1.5">
                  <span aria-hidden="true">{flag.emoji}</span>
                  <span>{item.localizedCountryLabel} ({item.countryCode})</span>
                </span>
              </td>
              <td class="font-bold font-mono">
                {item.priceText}
              </td>
              <td class="font-mono text-base-content/70">
                {item.currencyCode}
              </td>
              <td class="font-bold text-primary font-mono text-base">
                {item.equivalentPriceText}
              </td>
            </tr>
            );
          })}
          {currentGroup.prices.length === 0 && (
            <tr>
              <td colspan="5" class="p-8 text-center text-base-content/40">
                {t.officialPrice.empty}
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </section>
)}

{groups.length === 0 && (
  <section class="alert alert-info alert-soft max-w-md mx-auto my-6 justify-center">
    <span>{t.officialPrice.empty}</span>
  </section>
)}
