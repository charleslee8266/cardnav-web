---
/*
文件说明: 渲染 CardNav 公开站点赞助商展示区，供首页和内容页复用。
*/
import { telegramGroupUrl } from '../site.js';

const t = Astro.locals.messages;
const sponsorAnyRouterUrl = 'https://anyrouter.top/register?aff=JA5h';
const sponsorPackyApiUrl = 'https://www.packyapi.com/register?aff=Nulo';
const sponsorRightCodeUrl = 'https://www.right.codes/register?aff=84ba7fb0';
const sponsorPrimaryUrl = 'https://my.racknerd.com/aff.php?aff=20079&pid=952';
const sponsorPlan2c2gUrl = 'https://my.racknerd.com/aff.php?aff=20079&pid=953';
const sponsorPlan3c4gUrl = 'https://my.racknerd.com/aff.php?aff=20079&pid=954';
const sponsorPlan6c6gUrl = 'https://my.racknerd.com/aff.php?aff=20079&pid=955';
const sponsorPlan7c8gUrl = 'https://my.racknerd.com/aff.php?aff=20079&pid=956';
---

<section class="sponsor-section">
  <div class="sponsor-header">
    <h2 class="sponsor-title">{t.sponsors.title}</h2>
    <a href={telegramGroupUrl} target="_blank" rel="noopener noreferrer" data-umami-event="sponsor-lead-click" data-umami-event-url={telegramGroupUrl} data-umami-event-name={t.sponsors.becomeSponsor} class="sponsor-join-link">{t.sponsors.becomeSponsor}</a>
  </div>
  <div class="sponsor-grid">
    <article class="sponsor-card">
      <a href={sponsorAnyRouterUrl} target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url={sponsorAnyRouterUrl} class="sponsor-main-link group">
        <span class="sponsor-logo-frame sponsor-logo-frame-padded">
          <img src="/anyrouter.png" alt={t.sponsors.anyRouter.alt} width="440" height="146" loading="lazy" class="sponsor-logo sponsor-logo-contain" />
        </span>
        <span class="sponsor-name">
          {t.sponsors.anyRouter.name}
        </span>
        <span class="sponsor-copy">{t.sponsors.anyRouter.description}</span>
      </a>
    </article>
    <article class="sponsor-card">
      <a href={sponsorPackyApiUrl} target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url={sponsorPackyApiUrl} class="sponsor-main-link group">
        <span class="sponsor-logo-frame">
          <img src="https://www.packyapi.com/logo-full.svg" alt={t.sponsors.packyApi.alt} width="320" height="73" loading="lazy" class="sponsor-logo" />
        </span>
        <span class="sponsor-name">
          {t.sponsors.packyApi.name}
        </span>
        <span class="sponsor-copy">{t.sponsors.packyApi.description}</span>
      </a>
    </article>
    <article class="sponsor-card">
      <a href={sponsorRightCodeUrl} target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url={sponsorRightCodeUrl} class="sponsor-main-link group">
        <span class="sponsor-logo-frame">
          <img src="/rightcode.webp" alt={t.sponsors.rightCode.alt} width="1150" height="332" loading="lazy" class="sponsor-logo" />
        </span>
        <span class="sponsor-name">
          {t.sponsors.rightCode.name}
        </span>
        <span class="sponsor-copy">{t.sponsors.rightCode.description}</span>
      </a>
    </article>
    <article class="sponsor-card">
      <a href={sponsorPrimaryUrl} target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url={sponsorPrimaryUrl} class="sponsor-plan-main-link group">
        <span class="sponsor-logo-frame">
          <img src="https://racknerd.com/banners/320x100.gif" alt={t.sponsors.rackNerd.alt} width="320" height="100" loading="lazy" class="sponsor-banner" />
        </span>
        <span class="sponsor-plan-title">
          <span class="sponsor-plan-name">{t.sponsors.rackNerd.name}</span>
          <span class="sponsor-plan-price">{t.sponsors.rackNerd.price}</span>
        </span>
      </a>
      <div class="sponsor-plan-grid">
        <a href={sponsorPlan2c2gUrl} target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url={sponsorPlan2c2gUrl} class="sponsor-plan-link">{t.sponsors.rackNerd.plans[0]}</a>
        <a href={sponsorPlan3c4gUrl} target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url={sponsorPlan3c4gUrl} class="sponsor-plan-link">{t.sponsors.rackNerd.plans[1]}</a>
        <a href={sponsorPlan6c6gUrl} target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url={sponsorPlan6c6gUrl} class="sponsor-plan-link">{t.sponsors.rackNerd.plans[2]}</a>
        <a href={sponsorPlan7c8gUrl} target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url={sponsorPlan7c8gUrl} class="sponsor-plan-link">{t.sponsors.rackNerd.plans[3]}</a>
      </div>
    </article>
  </div>
</section>
