---
/*
文件说明: 统一公开站内页（非首页）Hero 区块的卡片容器、标题层级和可选返回链接。
*/
import PageBackLink from './PageBackLink.astro';

type Props = {
  title: string;
  description?: string;
  backHref?: string;
  backLabel?: string;
  titleId?: string;
  descriptionId?: string;
  heading?: 'h1' | 'h2';
  compact?: boolean;
  wrapCard?: boolean;
  titleClass?: string;
  copyClass?: string;
};

const {
  title,
  description = '',
  backHref,
  backLabel = '',
  titleId,
  descriptionId,
  heading = 'h1',
  compact = false,
  wrapCard = true,
  titleClass = '',
  copyClass = '',
} = Astro.props;

const HeadingTag = heading;
const hasAside = Astro.slots.has('aside');
const linkTo = Astro.locals.localizePath;
const backLinkHref = backHref ? linkTo(backHref) : '';

const heroBodyClass = ['page-hero-wrap', compact && 'space-y-3'].filter(Boolean);
const titleClassName = ['page-hero-title', compact && 'mt-0', titleClass].filter(Boolean);
const copyClassName = ['page-hero-copy', copyClass].filter(Boolean);
---

{wrapCard ? (
  <section class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body p-5">
      {hasAside ? (
        <div class="page-hero-shell">
          <div class="page-hero-main">
            <div class:list={heroBodyClass}>
              {backLinkHref && backLabel && (
                <div class="flex flex-wrap items-center gap-2">
                  <PageBackLink href={backLinkHref} label={backLabel} />
                </div>
              )}
              <slot name="title">
                <HeadingTag id={titleId} class:list={titleClassName}>{title}</HeadingTag>
              </slot>
              {description && <p id={descriptionId} class:list={copyClassName}>{description}</p>}
              <slot name="note" />
              <slot name="meta" />
              <slot name="actions" />
            </div>
          </div>
          <slot name="aside" />
        </div>
      ) : (
        <div class:list={heroBodyClass}>
          {backLinkHref && backLabel && (
            <div class="flex flex-wrap items-center gap-2">
              <PageBackLink href={backLinkHref} label={backLabel} />
            </div>
          )}
          <slot name="title">
            <HeadingTag id={titleId} class:list={titleClassName}>{title}</HeadingTag>
          </slot>
          {description && <p id={descriptionId} class:list={copyClassName}>{description}</p>}
          <slot name="note" />
          <slot name="meta" />
          <slot name="actions" />
        </div>
      )}
      <slot name="footer" />
    </div>
  </section>
) : (
  <div class:list={heroBodyClass}>
    {backLinkHref && backLabel && (
      <div class="flex flex-wrap items-center gap-2">
        <PageBackLink href={backLinkHref} label={backLabel} />
      </div>
    )}
    <slot name="title">
      <HeadingTag id={titleId} class:list={titleClassName}>{title}</HeadingTag>
    </slot>
    {description && <p id={descriptionId} class:list={copyClassName}>{description}</p>}
    <slot name="note" />
    <slot name="meta" />
    <slot name="actions" />
  </div>
)}