---
/*
文件说明: 渲染公开站点 Markdown 内容页正文，供默认语言和带语言前缀的静态页面复用。
*/
import type { RenderedPageContent } from '../page-content.js';

type Props = {
  content: RenderedPageContent;
};

const { content } = Astro.props;
---

<article class="content-page rounded border bg-base-100 px-4 py-5 text-base-content/90 md:px-8 md:py-7" set:html={content.html} />
