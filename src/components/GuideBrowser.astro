---
/*
文件说明: 渲染向导双栏浏览界面，左侧显示文档列表，右侧显示当前文档正文和赞助区。
*/
import Sponsors from './Sponsors.astro';
import pageWidgetsScriptUrl from '../scripts/page-widgets.js?url';
import type { GuideArticle, GuideNavItem, RenderedGuideArticle } from '../guide.js';

type Props = {
  articles: GuideArticle[];
  navItems: GuideNavItem[];
  currentArticle: RenderedGuideArticle;
  sourcePage: string;
};

const {
  navItems,
  currentArticle,
  sourcePage,
} = Astro.props;

const t = Astro.locals.messages;
const linkTo = Astro.locals.localizePath;
const guideUrlClickEventName = 'guide-url-click';

function guideUrlClickAttrs(targetPage: string) {
  const localizedTargetPage = linkTo(targetPage);
  return {
    'data-umami-event': guideUrlClickEventName,
    'data-umami-event-source-page': linkTo(sourcePage),
    'data-umami-event-target-page': localizedTargetPage,
    'data-umami-event-url': localizedTargetPage,
  };
}

function localizeRenderedGuideLinks(html: string) {
  return html.replace(/href="(\/guide[^"]*)"/gu, (_match, href: string) => `href="${linkTo(href)}"`);
}

const localizedArticleHtml = localizeRenderedGuideLinks(currentArticle.html);
---

<section class="guide-browser-grid h-full min-h-0 grid gap-4 lg:grid-cols-[18rem_minmax(0,1fr)]">
  <aside class="guide-sidebar card bg-base-100 border border-base-300 shadow-sm overflow-hidden">
    <details class="guide-sidebar-disclosure">
      <summary class="guide-sidebar-summary">
        <span class="min-w-0">
          <span class="guide-sidebar-kicker">Guide</span>
          <span class="guide-sidebar-current">{currentArticle.title}</span>
        </span>
        <span class="guide-sidebar-summary-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </span>
      </summary>
    </details>
    <div class="guide-sidebar-header border-b border-base-300 bg-base-200 px-4 py-3">
      <h2 class="mt-1 text-lg font-bold text-base-content">{t.guide.allDocs}</h2>
    </div>
    <nav aria-label={t.guide.docListLabel} class="guide-sidebar-scroll p-2">
      <ul class="space-y-1">
        {navItems.map(item => {
          const article = item.article;
          const isActive = article.slug === currentArticle.slug;
          return (
            <li>
              <a
                href={linkTo(`/guide/${article.slug}`)}
                aria-current={isActive ? 'page' : undefined}
                data-guide-current={isActive ? 'true' : undefined}
                {...guideUrlClickAttrs(`/guide/${article.slug}`)}
                class:list={[
                  'guide-sidebar-link block rounded-xl border px-3 py-1.5 transition-colors',
                  item.depth > 0 && 'guide-sidebar-link-child',
                  isActive
                    ? 'border-primary/25 bg-primary/8 text-primary'
                    : 'border-transparent text-base-content/80 hover:border-base-300 hover:bg-base-200/70 hover:text-base-content',
                ]}
                style={`padding-left: ${0.75 + item.depth * 1.1}rem;`}
              >
                <span class:list={[
                  'block leading-5',
                  item.depth === 0 ? 'text-sm font-semibold' : 'text-[13px] font-medium',
                  isActive && 'font-bold'
                ]}>{article.title}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </aside>

  <section class="guide-content-scroll min-w-0 space-y-4">
    <section class="guide-shell rounded-[1.75rem] border border-base-300 bg-base-100 p-5 shadow-sm md:p-7">
      <div class="guide-hero">
        <p class="guide-eyebrow">{t.guide.eyebrow}</p>
        <h1 class="guide-title">{currentArticle.title}</h1>
      </div>
      <div class="guide-article guide-intro mt-6 p-0 border-0 bg-transparent text-base-content/90" set:html={localizedArticleHtml} />
    </section>

    {currentArticle.nextLink && (
      <a
        href={linkTo(`/guide/${currentArticle.nextLink.slug}`)}
        {...guideUrlClickAttrs(`/guide/${currentArticle.nextLink.slug}`)}
        class="guide-next-step block rounded-2xl border border-base-300 bg-base-100 px-5 py-4 shadow-sm no-underline transition duration-200 hover:border-primary/30 hover:bg-primary/[0.02] active:scale-[0.99]"
      >
        <p class="guide-next-step-label">{t.guide.nextStep}</p>
        <span class="guide-next-step-link mt-2 inline-flex text-lg font-bold text-primary">
          {currentArticle.nextLink.title || currentArticle.nextLink.slug}
        </span>
      </a>
    )}

    <Sponsors />

    <nav class="guide-mini-footer flex flex-wrap items-center justify-center gap-2 border-t border-base-300 pt-4 text-xs text-base-content/60" aria-label={t.nav.about}>
      <a href={linkTo('/about')} class="link link-hover font-semibold text-base-content/75">{t.nav.about}</a>
      <span aria-hidden="true">|</span>
      <a href={linkTo('/disclaimer')} class="link link-hover font-semibold text-base-content/75">{t.nav.disclaimer}</a>
      <span aria-hidden="true">|</span>
      <a href={linkTo('/privacy')} class="link link-hover font-semibold text-base-content/75">{t.nav.privacy}</a>
    </nav>
  </section>
</section>
<script is:inline slot="scripts" defer src={pageWidgetsScriptUrl}></script>
