---
/*
文件说明: 渲染 CardNav 公开首页，按卡片模块展示模型、订阅价格、热门产品和卡网商家入口。
*/
import PublicPage from '../layouts/PublicPage.astro';
import Sponsors from '../components/Sponsors.astro';
import { buildSeoContext } from '../seo.js';
import { publicSiteUrl } from '../site.js';
import { loadDashboardData, loadModelLeaderboards, loadOfficialPrices, loadPopularSearchTerms } from '../store.js';

const dashboardData = await loadDashboardData({ productLimit: 10 });
const leaderboardRows = await loadModelLeaderboards();
const officialPrices = await loadOfficialPrices();
const popularSearchTerms = (await loadPopularSearchTerms(10)).terms
  .map(term => term.trim())
  .filter(Boolean);

const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/',
  title: '卡网大全 - 一站式 AI 大模型账号购买导航',
  description: '汇总 AI 大模型排行榜、官方 AI 订阅渠道、第三方 AI 卡网比价、实用工具、风险控制、使用指南，帮你少踩坑、少花钱。GPT，Claude，Gemini，Cursor，Grok 应有尽有。',
  imagePath: '/og-cardnav.svg',
  type: 'website',
});

const taskOrder = ['coding', 'creative-writing', 'math', 'text-to-image'];
type LeaderboardPreviewGroup = {
  taskSlug: string;
  taskLabel: string;
  rows: typeof leaderboardRows;
};

const taskGroups: LeaderboardPreviewGroup[] = taskOrder
  .map(taskSlug => {
    const rows = leaderboardRows.filter(row => row.taskSlug === taskSlug).slice(0, 3);
    if (rows.length === 0) return null;
    return {
      taskSlug,
      taskLabel: rows[0]?.taskLabel || taskSlug,
      rows,
    };
  })
  .filter((group): group is LeaderboardPreviewGroup => group !== null);

const appLabelMap = {
  'chatgpt': 'ChatGPT',
  'claude': 'Claude',
  'gemini': 'Gemini',
  'grok': 'Grok',
  'copilot': 'Copilot',
  'kimi': 'Kimi',
  'x': 'X',
};

const planLabelMap = {
  'go-monthly': 'Go',
  'plus': 'Plus',
  'pro-5x': 'Pro 5x',
  'pro-20x': 'Pro 20x',
  'pro': 'Pro',
  'max-5x-monthly': 'Max 5x',
  'max-20x-monthly': 'Max 20x',
  'ai-plus': 'AI Plus',
  'advanced': 'AI Pro',
  'ai-ultra': 'AI Ultra',
  'supergrok-lite': 'SuperGrok Lite',
  'supergrok': 'SuperGrok',
  'supergrok-heavy': 'SuperGrok Heavy',
  'moderato': 'Moderato',
  'allegretto': 'Allegretto',
  'basic': 'Basic',
  'premium': 'Premium',
  'premium-plus': 'Premium+',
};

function labelFromSlug(slug: string) {
  return slug
    .split('-')
    .filter(Boolean)
    .map(part => part.length <= 3 ? part.toUpperCase() : `${part[0]?.toUpperCase() || ''}${part.slice(1)}`)
    .join(' ');
}

function appLabel(appSlug: string) {
  return appLabelMap[appSlug as keyof typeof appLabelMap] || labelFromSlug(appSlug);
}

function planLabel(planSlug: string) {
  return planLabelMap[planSlug as keyof typeof planLabelMap] || labelFromSlug(planSlug);
}

const officialPriceTargets = [
  { appSlug: 'chatgpt', planSlug: 'pro-20x' },
  { appSlug: 'claude', planSlug: 'max-20x-monthly' },
  { appSlug: 'gemini', planSlug: 'ai-ultra' },
];

const officialPriceGroups = officialPriceTargets
  .map(target => {
    const prices = officialPrices
      .filter(item => item.appSlug === target.appSlug && item.planSlug === target.planSlug)
      .slice()
      .sort((left, right) => left.cnyPrice - right.cnyPrice)
      .slice(0, 3);
    return {
      key: `${target.appSlug}:${target.planSlug}`,
      appName: appLabel(target.appSlug),
      planName: planLabel(target.planSlug),
      prices,
    };
  })
  .filter(group => group.prices.length > 0);

const hotProducts = dashboardData.products.slice(0, 10).map(product => ({
  ...product,
  displayPrice: typeof product.priceNumber === 'number' && product.priceUnit
    ? `${product.priceUnit}${String(product.priceNumber)}`
    : product.price,
}));

const guideSteps = [
  { title: '选择你想使用的 AI 大模型', href: '/guide/choose-model' },
  { title: '选择 AI 订阅使用方式', href: '/guide/choose-usage-method' },
  { title: 'AI 订阅实操准备与选购避坑', href: '/guide/practical-prep' },
  { title: 'AI 订阅使用期间的风控与日常避坑', href: '/guide/daily-usage-risk' },
];

const guideSourcePage = '/';

function guideUrlClickAttrs(targetPage: string) {
  return {
    'data-umami-event': 'guide-url-click',
    'data-umami-event-source-page': guideSourcePage,
    'data-umami-event-target-page': targetPage,
    'data-umami-event-url': targetPage,
  };
}

function homeCtaClickAttrs(targetPage: string, name: string) {
  return {
    'data-umami-event': 'home-cta-click',
    'data-umami-event-name': name,
    'data-umami-event-target-page': targetPage,
    'data-umami-event-url': targetPage,
  };
}

---

<PublicPage activeNav="home" showSponsors={false} {...seo}>
  <section class="card relative cursor-pointer bg-base-100 border border-base-300 shadow-sm overflow-hidden transition hover:border-primary/35 hover:shadow-md">
    <a href="/guide" class="absolute inset-0 z-0" aria-label="打开完整向导" {...guideUrlClickAttrs('/guide')}></a>
    <div class="card-body p-4">
      <div class="relative z-10 flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
        <div>
          <h2 class="text-xl font-bold text-base-content">不知道如何开始？点击进入向导</h2>
          <p class="mt-1 text-sm leading-6 text-base-content/75">从模型选择、使用方式到实践，先把思路理清楚。</p>
        </div>
        <a href="/guide" class="btn btn-outline btn-sm shrink-0" {...guideUrlClickAttrs('/guide')}>打开完整向导</a>
      </div>
      <div class="relative z-10 mt-3 grid gap-2 md:grid-cols-2 xl:grid-cols-4">
        {guideSteps.map((step, index) => (
          <a href={step.href} class="rounded-lg border border-base-300 bg-base-100 px-3 py-2 no-underline transition hover:border-primary/35 hover:bg-base-200/50" {...guideUrlClickAttrs(step.href)}>
            <span class="text-xs font-semibold text-primary">步骤 {index + 1}</span>
            <span class="mt-1 block text-sm font-bold text-base-content">{step.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="grid gap-3 xl:grid-cols-3">
    <article class="card bg-base-100 border border-base-300 shadow-sm">
      <div class="card-body p-5">
        <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-xl font-bold text-base-content">AI 大模型排行榜</h2>
            <p class="text-sm leading-6 text-base-content/75">不同场景下的模型排行</p>
          </div>
          <a href="/model-leaderboard" class="btn btn-outline btn-sm shrink-0" {...homeCtaClickAttrs('/model-leaderboard', '查看完整榜单')}>查看完整榜单</a>
        </div>
        <div class="mt-3 grid gap-3 md:grid-cols-2 xl:grid-cols-1">
          {taskGroups.map(group => (
            <article class="rounded-2xl border border-base-300 bg-base-100 p-4">
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-lg font-bold text-base-content">{group.taskLabel}</h3>
                <span class="badge badge-ghost badge-sm font-medium">Top 3</span>
              </div>
              <div class="mt-3 space-y-3">
                {group.rows.map(item => (
                  <div class="flex items-center justify-between gap-3 rounded-xl bg-base-200/45 px-3 py-2">
                    <div class="min-w-0">
                      <p class="text-sm font-semibold text-base-content">#{item.rank} {item.modelName}</p>
                    </div>
                    <span class="text-sm font-mono font-bold text-primary">{item.score.toFixed(2)}</span>
                  </div>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </article>

    <article class="card bg-base-100 border border-base-300 shadow-sm">
      <div class="card-body p-5">
        <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-xl font-bold text-base-content">官方 AI 订阅比价</h2>
            <p class="text-sm leading-6 text-base-content/75">全球不同地区官方订阅价格对比</p>
          </div>
          <a href="/official-price" class="btn btn-outline btn-sm shrink-0" {...homeCtaClickAttrs('/official-price', '进入比价页')}>进入比价页</a>
        </div>
        <div class="mt-3 space-y-3">
          {officialPriceGroups.map(group => (
            <section class="rounded-2xl border border-base-300 bg-base-100 p-4">
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-base font-bold text-base-content">{group.appName} {group.planName}</h3>
                <span class="badge badge-ghost badge-sm font-medium">低价地区</span>
              </div>
              <div class="mt-3 space-y-2">
                {group.prices.map((item, index) => (
                  <div class="flex items-center justify-between gap-3 rounded-xl bg-base-200/45 px-3 py-2">
                    <div class="min-w-0">
                      <p class="text-sm font-semibold text-base-content">#{index + 1} {item.countryLabel}</p>
                      <p class="text-xs text-base-content/65">{item.countryCode} · {item.priceText}</p>
                    </div>
                    <p class="min-w-16 text-right text-sm font-bold text-primary">¥{item.cnyPrice}</p>
                  </div>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </article>

    <article class="card bg-base-100 border border-base-300 shadow-sm">
      <div class="card-body p-5">
        <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-xl font-bold text-base-content">热门 AI 卡网商品</h2>
            <p class="text-sm leading-6 text-base-content/75">全网第三方 AI 卡网商家与商品搜索</p>
          </div>
          <a href="/shops" class="btn btn-outline btn-sm shrink-0" {...homeCtaClickAttrs('/shops', '进入卡网商家页')}>进入卡网商家页</a>
        </div>

        <div class="mt-3 space-y-3">
          <div class="collection-summary flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-base-content/70">
            <span>已收录商家：<span class="font-bold text-primary">{dashboardData.totalSiteCount}</span></span>
            <span>商品：<span class="font-bold text-primary">{dashboardData.totalProductCount}</span></span>
            {dashboardData.latestRefreshTime && <span>最近刷新：{dashboardData.latestRefreshTime}</span>}
          </div>

          <form action="/shops" method="get" class="flex flex-col gap-3">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-center">
              <input name="q" type="search" class="input input-bordered w-full" placeholder="搜索商品、商家关键词" autocomplete="off" />
              <button type="submit" class="btn btn-primary shrink-0" data-umami-event="home-search-submit" data-umami-event-name="首页搜索" data-umami-event-target-page="/shops">搜索</button>
            </div>
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-sm font-semibold text-base-content/65 uppercase tracking-wider">热门搜索</span>
              {popularSearchTerms.map(term => (
                <a
                  href={`/shops?q=${encodeURIComponent(term)}`}
                  class="btn btn-outline btn-sm rounded-full border-base-300 font-semibold text-base-content/85 hover:text-base-content! hover:border-base-content/30! hover:bg-base-200!"
                  data-umami-event="home-hot-search-click"
                  data-umami-event-name={term}
                  data-umami-event-target-page={`/shops?q=${encodeURIComponent(term)}`}
                  data-umami-event-url={`/shops?q=${encodeURIComponent(term)}`}
                >
                  {term}
                </a>
              ))}
            </div>
          </form>

          <div class="space-y-2">
            {hotProducts.map(item => (
              <div class="flex items-center justify-between gap-3 rounded-xl bg-base-200/45 px-3 py-3">
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-base-content">{item.name}</p>
                  <p class="text-xs text-base-content/65">{item.siteName} · {item.categoryName}</p>
                </div>
                <div class="text-right">
                  <p class="text-sm font-bold text-primary">{item.displayPrice}</p>
                  <p class="text-xs text-base-content/60">{item.inStock ? '有货' : '缺货'}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </article>
  </section>

  <section class="grid gap-4 lg:grid-cols-2">
    <a href="/tools" class="card bg-base-100 border border-base-300 shadow-sm no-underline transition hover:-translate-y-0.5 hover:border-primary/35 hover:shadow-md" {...homeCtaClickAttrs('/tools', '打开工具集')}>
      <div class="card-body p-5">
        <span class="badge badge-ghost badge-sm w-fit font-medium">实用工具</span>
        <h2 class="mt-2 text-xl font-bold text-base-content">AI 订阅工具集</h2>
        <p class="mt-2 text-sm leading-6 text-base-content/75">把 IP 纯净度检测、Session 转换等工具集中放到一起，真正操作时不用来回找。</p>
        <span class="mt-4 text-sm font-semibold text-primary">打开工具集</span>
      </div>
    </a>
    <a href="/guide" class="card bg-base-100 border border-base-300 shadow-sm no-underline transition hover:-translate-y-0.5 hover:border-primary/35 hover:shadow-md" {...guideUrlClickAttrs('/guide')}>
      <div class="card-body p-5">
        <span class="badge badge-ghost badge-sm w-fit font-medium">购买向导</span>
        <h2 class="mt-2 text-xl font-bold text-base-content">继续看向导</h2>
        <p class="mt-2 text-sm leading-6 text-base-content/75">如果你更在意怎么选、怎么买、怎么买得更稳，那就继续顺着向导往下走。</p>
        <span class="mt-4 text-sm font-semibold text-primary">继续看向导</span>
      </div>
    </a>
  </section>

  <Sponsors />
</PublicPage>
