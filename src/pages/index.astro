---
/*
文件说明: 渲染 CardNav 公开首页，按卡片模块展示模型、订阅价格、热门产品和卡网商家入口。
*/
import PublicPage from '../layouts/PublicPage.astro';
import Sponsors from '../components/Sponsors.astro';
import { localizeModelLeaderboardGroups, localizeOfficialPriceGroups } from '../localized-display.js';
import { buildModelLeaderboardGroups } from '../model-leaderboard.js';
import { buildOfficialPriceGroups } from '../official-price.js';
import { buildSeoContext } from '../seo.js';
import { publicSiteUrl } from '../site.js';
import {
  loadDashboardData,
  loadModelLeaderboards,
  loadOfficialPrices,
  loadPopularSearchTerms,
  loadGatewayModels,
  loadGatewaySites,
} from '../store.js';

const t = Astro.locals.messages;
const linkTo = Astro.locals.localizePath;
const [
  dashboardData,
  popularSearchSnapshot,
  officialPrices,
  leaderboardRows,
  gatewayData,
  gatewayModelData,
] = await Promise.all([
  loadDashboardData({ productLimit: 6 }),
  loadPopularSearchTerms(10, [...t.home.presetPopularSearchTerms]),
  loadOfficialPrices(),
  loadModelLeaderboards(),
  loadGatewaySites(),
  loadGatewayModels(),
]);
const popularSearchTerms = popularSearchSnapshot.terms
  .map(term => term.trim())
  .filter(Boolean);

const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/',
  title: t.home.seoTitle,
  description: t.home.seoDescription,
  imagePath: '/og-cardnav.png',
  type: 'website',
  locale: Astro.locals.locale,
});

const guideSourcePage = '/';

const primaryCards = [
  {
    title: t.home.gatewayPathTitle,
    description: t.home.gatewayPathShortDescription,
    href: '/llm-gateway',
    action: t.home.openGateway,
    name: t.home.gatewayPathTitle,
    badge: t.nav.llmGateway,
  },
  {
    title: t.home.shopPathTitle,
    description: t.home.shopPathShortDescription,
    href: '/shops',
    action: t.actions.openShops,
    name: t.home.shopPathTitle,
    badge: t.nav.shops,
  },
  {
    title: t.home.officialPathTitle,
    description: t.home.officialPathShortDescription,
    href: '/official-price',
    action: t.actions.openPricePage,
    name: t.home.officialPathTitle,
    badge: t.nav.officialPrice,
  },
];

const secondaryCards = [
  {
    title: t.home.leaderboardPathTitle,
    description: t.home.leaderboardPathShortDescription,
    href: '/model-leaderboard',
    action: t.actions.viewFullLeaderboard,
    name: t.home.leaderboardPathTitle,
    badge: t.nav.modelLeaderboard,
    eventAttrs: homeCtaClickAttrs('/model-leaderboard', t.home.leaderboardPathTitle),
  },
  {
    title: t.home.guidePathTitle,
    description: t.home.guidePathShortDescription,
    href: '/guide',
    action: t.actions.openGuide,
    name: t.home.guidePathTitle,
    badge: t.nav.guide,
    eventAttrs: guideUrlClickAttrs('/guide'),
  },
];

const toolCards = [
  {
    title: t.tools.ipPurity.title,
    description: t.home.ipToolDescription,
    href: '/tools/ip-purity',
  },
  {
    title: t.tools.sessionConverter.title,
    description: t.home.sessionToolDescription,
    href: '/tools/session-converter',
  },
];

const guideHighlightSteps: Array<{ title: string; href: string }> = t.home.guideSteps;

const officialPriceGroups = localizeOfficialPriceGroups(
  buildOfficialPriceGroups(officialPrices),
  Astro.locals.locale,
);
type OfficialPriceHighlightGroup = (typeof officialPriceGroups)[number];
const preferredOfficialPlans = [
  { app: 'chatgpt', plan: 'plus' },
  { app: 'gpt', plan: '20x' },
  { app: 'claude', plan: 'pro' },
  { app: 'claude', plan: '20x' },
];
const pickedOfficialKeys = new Set<string>();
const officialPriceHighlights = preferredOfficialPlans
  .map(({ app, plan }) => officialPriceGroups.find(group => {
    const haystack = `${group.appSlug} ${group.planSlug} ${group.appName} ${group.planName} ${group.displayName} ${group.urlSlug}`.toLowerCase();
    return haystack.includes(app) && haystack.includes(plan);
  }))
  .filter((group): group is OfficialPriceHighlightGroup => Boolean(group))
  .filter(group => {
    if (!group || pickedOfficialKeys.has(group.key)) return false;
    pickedOfficialKeys.add(group.key);
    return group.prices.length >= 3;
  })
  .map(group => ({
    title: group.displayName,
    href: group.pathname,
    prices: group.prices.slice(0, 3).map(price => ({
      country: price.localizedCountryLabel,
      localPrice: price.priceText,
      equivalentPrice: price.equivalentPriceText,
    })),
  }));

const modelHighlightGroups = localizeModelLeaderboardGroups(
  buildModelLeaderboardGroups(leaderboardRows),
  t,
)
  .map(group => ({
    title: group.displayName,
    href: group.pathname,
    rows: group.rows.slice(0, 3).map(row => ({
      rank: row.rank,
      modelName: row.modelName,
    })),
  }));

const gatewayHighlights = gatewayData.sites.slice(0, 4).map(site => ({
  title: site.name,
  meta: site.displayModelFamilies.slice(0, 3).join(' / ') || site.host,
  value: site.modelCount > 0 ? t.home.gatewayModelCountLabel.replace('{count}', String(site.modelCount)) : t.home.noGatewayModelData,
  href: `/llm-gateway/${site.slug}`,
}));

const gatewayModelHighlights = gatewayModelData.models.slice(0, 4).map(model => ({
  title: model.modelId,
  meta: model.modelFamily,
  value: t.home.gatewaySupportCountLabel.replace('{count}', String(model.supportSiteCount)),
  href: `/llm-gateway/models/${encodeURIComponent(model.modelId)}`,
}));

const productHighlights = dashboardData.products.slice(0, 6).map(product => ({
  title: product.name,
  meta: `${product.siteName} · ${product.categoryName}`,
  value: typeof product.priceNumber === 'number' && product.priceUnit
    ? `${product.priceUnit}${String(product.priceNumber)}`
    : product.price,
  href: `/shops?q=${encodeURIComponent(product.name)}`,
}));

function guideUrlClickAttrs(targetPage: string) {
  const localizedTargetPage = linkTo(targetPage);
  return {
    'data-umami-event': 'guide-url-click',
    'data-umami-event-source-page': linkTo(guideSourcePage),
    'data-umami-event-target-page': localizedTargetPage,
    'data-umami-event-url': localizedTargetPage,
  };
}

function homeCtaClickAttrs(targetPage: string, name: string) {
  const localizedTargetPage = linkTo(targetPage);
  return {
    'data-umami-event': 'home-cta-click',
    'data-umami-event-name': name,
    'data-umami-event-target-page': localizedTargetPage,
    'data-umami-event-url': localizedTargetPage,
  };
}

---

<PublicPage activeNav="home" showSponsors={false} {...seo}>
  <section class="site-main-width mt-4">
    <div>
      <div class="mb-4">
        <h2 class="text-2xl font-bold tracking-normal text-base-content md:text-3xl">{t.home.quickNavTitle}</h2>
      </div>
      <div class="grid grid-cols-[minmax(0,1fr)] gap-4 md:grid-cols-3">
        {primaryCards.map(card => (
          <a href={linkTo(card.href)} class="group flex min-w-0 flex-col rounded-lg border border-base-300 bg-base-100 p-4 no-underline transition hover:-translate-y-0.5 hover:border-primary/35 hover:shadow-md" {...homeCtaClickAttrs(card.href, card.name)}>
            <span class="badge badge-ghost badge-sm w-fit font-medium">{card.badge}</span>
            <h3 class="mt-3 text-xl font-bold text-base-content">{card.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-6 text-base-content/72">{card.description}</p>
            <span class="mt-4 text-sm font-semibold text-primary">{card.action}</span>
          </a>
        ))}
      </div>

      <div class="mt-4 grid grid-cols-[minmax(0,1fr)] gap-4 md:grid-cols-2">
        {secondaryCards.map(card => (
          <a href={linkTo(card.href)} class="group flex min-w-0 flex-col rounded-lg border border-base-300 bg-base-100 p-4 no-underline transition hover:-translate-y-0.5 hover:border-primary/35 hover:shadow-md" {...card.eventAttrs}>
            <span class="badge badge-ghost badge-sm w-fit font-medium">{card.badge}</span>
            <h3 class="mt-3 text-xl font-bold text-base-content">{card.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-6 text-base-content/72">{card.description}</p>
            <span class="mt-4 text-sm font-semibold text-primary">{card.action}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="site-main-width mt-4 grid grid-cols-[minmax(0,1fr)] gap-5">
    <div>
      <h2 class="text-2xl font-bold tracking-normal text-base-content md:text-3xl">{t.home.highlightsTitle}</h2>
    </div>

    <article class="card bg-base-100 border border-base-300 shadow-sm">
      <div class="card-body gap-4 p-4">
        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-lg font-bold text-base-content">
              <a href={linkTo('/llm-gateway')} class="text-base-content no-underline hover:text-primary" {...homeCtaClickAttrs('/llm-gateway', t.home.openGateway)}>{t.home.gatewayHighlightsTitle}</a>
            </h2>
          </div>
          <a href={linkTo('/llm-gateway')} class="btn btn-outline btn-sm shrink-0" {...homeCtaClickAttrs('/llm-gateway', t.home.openGateway)}>{t.home.openGateway}</a>
        </div>
        <div class="grid grid-cols-[minmax(0,1fr)] gap-4 lg:grid-cols-2">
          <section class="min-w-0 rounded-lg bg-base-200/45 p-3">
            <h3 class="text-sm font-bold text-base-content">{t.home.popularGatewaySitesTitle}</h3>
            <div class="mt-3 space-y-2">
              {gatewayHighlights.map(item => (
                <a href={linkTo(item.href)} class="flex items-center justify-between gap-3 rounded bg-base-100 px-3 py-2 no-underline transition hover:bg-base-200" {...homeCtaClickAttrs(item.href, item.title)}>
                  <span class="min-w-0">
                    <span class="block truncate text-sm font-semibold text-base-content">{item.title}</span>
                    <span class="block truncate text-xs text-base-content/60">{item.meta}</span>
                  </span>
                  <span class="shrink-0 text-right text-xs font-semibold text-primary">{item.value}</span>
                </a>
              ))}
            </div>
          </section>
          <section class="min-w-0 rounded-lg bg-base-200/45 p-3">
            <h3 class="text-sm font-bold text-base-content">{t.home.popularGatewayModelsTitle}</h3>
            <div class="mt-3 space-y-2">
              {gatewayModelHighlights.map(item => (
                <a href={linkTo(item.href)} class="flex items-center justify-between gap-3 rounded bg-base-100 px-3 py-2 no-underline transition hover:bg-base-200" {...homeCtaClickAttrs(item.href, item.title)}>
                  <span class="min-w-0">
                    <span class="block truncate text-sm font-semibold text-base-content">{item.title}</span>
                    <span class="block truncate text-xs text-base-content/60">{item.meta}</span>
                  </span>
                  <span class="shrink-0 text-right text-xs font-semibold text-primary">{item.value}</span>
                </a>
              ))}
            </div>
          </section>
        </div>
      </div>
    </article>

    <article class="card bg-base-100 border border-base-300 shadow-sm">
      <div class="card-body gap-4 p-4">
        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-lg font-bold text-base-content">
              <a href={linkTo('/shops')} class="text-base-content no-underline hover:text-primary" {...homeCtaClickAttrs('/shops', t.actions.openShops)}>{t.home.productHighlightsTitle}</a>
            </h2>
          </div>
          <a href={linkTo('/shops')} class="btn btn-outline btn-sm shrink-0" {...homeCtaClickAttrs('/shops', t.actions.openShops)}>{t.actions.openShops}</a>
        </div>
        <form action={linkTo('/shops')} method="get" class="flex flex-col gap-3 rounded-lg border border-base-300 bg-base-100 p-3" data-home-search-form>
          <div class="flex flex-col gap-3 lg:flex-row lg:items-center">
            <input name="q" type="search" class="input input-bordered w-full" placeholder={t.home.searchPlaceholder} autocomplete="off" data-home-search-input />
            <button type="submit" class="btn btn-primary shrink-0" data-umami-event="home-search-submit" data-umami-event-name={t.analytics.homeSearch} data-umami-event-query="" data-umami-event-target-page={linkTo('/shops')} data-umami-event-url={linkTo('/shops')}>{t.actions.search}</button>
          </div>
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-sm font-semibold uppercase tracking-wider text-base-content/65">{t.labels.popularSearch}</span>
            {popularSearchTerms.map(term => (
              <a href={`${linkTo('/shops')}?q=${encodeURIComponent(term)}`} class="btn btn-outline btn-sm rounded-full border-base-300 font-semibold text-base-content/85 hover:text-base-content! hover:border-base-content/30! hover:bg-base-200!" data-umami-event="home-hot-search-click" data-umami-event-name={term} data-umami-event-target-page={`${linkTo('/shops')}?q=${encodeURIComponent(term)}`} data-umami-event-url={`${linkTo('/shops')}?q=${encodeURIComponent(term)}`}>
                {term}
              </a>
            ))}
          </div>
          <div class="collection-summary flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-base-content/70">
            <span>{t.labels.collectedSites}: <span class="font-bold text-primary">{dashboardData.totalSiteCount}</span></span>
            <span>{t.labels.products}: <span class="font-bold text-primary">{dashboardData.totalProductCount}</span></span>
            {dashboardData.latestRefreshTime && <span>{t.labels.latestRefresh}: {dashboardData.latestRefreshTime}</span>}
          </div>
        </form>
        <div class="grid grid-cols-[minmax(0,1fr)] gap-3 md:grid-cols-2 xl:grid-cols-3">
          {productHighlights.map(item => (
            <a href={linkTo(item.href)} class="flex min-w-0 items-center justify-between gap-3 rounded-lg bg-base-200/45 px-4 py-3 no-underline transition hover:bg-base-200" {...homeCtaClickAttrs(item.href, item.title)}>
              <span class="block min-w-0 flex-1 max-w-full space-y-1 overflow-hidden">
                <span class="block max-w-full truncate text-sm font-semibold leading-5 text-base-content">{item.title}</span>
                <span class="block max-w-full truncate text-xs leading-5 text-base-content/60">{item.meta}</span>
              </span>
              <span class="shrink-0 text-right text-sm font-bold text-primary">{item.value}</span>
            </a>
          ))}
        </div>
      </div>
    </article>

    <article class="card bg-base-100 border border-base-300 shadow-sm">
      <div class="card-body gap-4 p-4">
        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-lg font-bold text-base-content">
              <a href={linkTo('/official-price')} class="text-base-content no-underline hover:text-primary" {...homeCtaClickAttrs('/official-price', t.actions.openPricePage)}>{t.home.officialHighlightsTitle}</a>
            </h2>
          </div>
          <a href={linkTo('/official-price')} class="btn btn-outline btn-sm shrink-0" {...homeCtaClickAttrs('/official-price', t.actions.openPricePage)}>{t.actions.openPricePage}</a>
        </div>
        <div class="grid grid-cols-[minmax(0,1fr)] gap-3 md:grid-cols-2 xl:grid-cols-4">
          {officialPriceHighlights.map(group => (
            <a href={linkTo(group.href)} class="min-w-0 rounded-lg bg-base-200/45 px-4 py-3 no-underline transition hover:bg-base-200" {...homeCtaClickAttrs(group.href, group.title)}>
              <h3 class="line-clamp-2 text-sm font-bold leading-5 text-base-content">{group.title}</h3>
              <div class="mt-3 space-y-2">
                {group.prices.map(price => (
                  <div class="flex items-center justify-between gap-3 text-sm">
                    <span class="min-w-0 truncate text-base-content/70">{price.country}</span>
                    <span class="shrink-0 font-bold text-primary">{price.equivalentPrice}</span>
                  </div>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </article>

    <article class="card bg-base-100 border border-base-300 shadow-sm">
      <div class="card-body gap-4 p-4">
        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-lg font-bold text-base-content">
              <a href={linkTo('/model-leaderboard')} class="text-base-content no-underline hover:text-primary" {...homeCtaClickAttrs('/model-leaderboard', t.actions.viewFullLeaderboard)}>{t.home.modelHighlightsTitle}</a>
            </h2>
          </div>
          <a href={linkTo('/model-leaderboard')} class="btn btn-outline btn-sm shrink-0" {...homeCtaClickAttrs('/model-leaderboard', t.actions.viewFullLeaderboard)}>{t.actions.viewFullLeaderboard}</a>
        </div>
        <div class="grid grid-cols-[minmax(0,1fr)] gap-3 md:grid-cols-2 xl:grid-cols-4">
          {modelHighlightGroups.map(group => (
            <a href={linkTo(group.href)} class="min-w-0 rounded-lg bg-base-200/45 px-4 py-3 no-underline transition hover:bg-base-200" {...homeCtaClickAttrs(group.href, group.title)}>
              <h3 class="text-sm font-bold text-base-content">{group.title}</h3>
              <div class="mt-3 space-y-2">
                {group.rows.map(row => (
                  <div class="text-sm">
                    <span class="block truncate text-base-content">#{row.rank} {row.modelName}</span>
                  </div>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </article>

    <article class="card bg-base-100 border border-base-300 shadow-sm">
      <div class="card-body gap-4 p-4">
        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-lg font-bold text-base-content">
              <a href={linkTo('/guide')} class="text-base-content no-underline hover:text-primary" {...guideUrlClickAttrs('/guide')}>{t.home.buyingGuideTitle}</a>
            </h2>
          </div>
          <a href={linkTo('/guide')} class="btn btn-outline btn-sm shrink-0" {...guideUrlClickAttrs('/guide')}>{t.actions.openGuide}</a>
        </div>
        <div class="grid grid-cols-[minmax(0,1fr)] gap-3 md:grid-cols-2">
          {guideHighlightSteps.map(step => (
            <a href={linkTo(step.href)} class="min-w-0 rounded-lg bg-base-200/45 px-4 py-3 no-underline transition hover:bg-base-200" {...guideUrlClickAttrs(step.href)}>
              <span class="block truncate text-sm font-semibold text-base-content">{step.title}</span>
            </a>
          ))}
        </div>
      </div>
    </article>

    <article class="card bg-base-100 border border-base-300 shadow-sm">
      <div class="card-body gap-4 p-4">
        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-lg font-bold text-base-content">
              <a href={linkTo('/tools')} class="text-base-content no-underline hover:text-primary" {...homeCtaClickAttrs('/tools', t.actions.openTools)}>{t.home.toolsTitle}</a>
            </h2>
          </div>
          <a href={linkTo('/tools')} class="btn btn-outline btn-sm shrink-0" {...homeCtaClickAttrs('/tools', t.actions.openTools)}>{t.actions.openTools}</a>
        </div>
        <div class="grid grid-cols-[minmax(0,1fr)] gap-3 md:grid-cols-2">
          {toolCards.map(tool => (
            <a href={linkTo(tool.href)} class="min-w-0 rounded-lg bg-base-200/45 px-4 py-3 no-underline transition hover:bg-base-200" {...homeCtaClickAttrs(tool.href, tool.title)}>
              <span class="block text-sm font-bold text-base-content">{tool.title}</span>
              <span class="mt-1 block text-sm leading-6 text-base-content/70">{tool.description}</span>
            </a>
          ))}
        </div>
      </div>
    </article>
  </section>

  <div class="site-main-width">
    <Sponsors />
  </div>
</PublicPage>

<script is:inline define:vars={{ shopsPath: linkTo('/shops') }}>
  const homeSearchForm = document.querySelector('[data-home-search-form]');
  const homeSearchInput = homeSearchForm?.querySelector('[data-home-search-input]');
  const homeSearchButton = homeSearchForm?.querySelector('[data-umami-event="home-search-submit"]');
  const syncHomeSearchEvent = () => {
    if (!homeSearchButton || !homeSearchInput) return;
    const query = homeSearchInput.value.trim();
    const targetPage = query ? `${shopsPath}?q=${encodeURIComponent(query)}` : shopsPath;
    homeSearchButton.dataset.umamiEventQuery = query;
    homeSearchButton.dataset.umamiEventUrl = targetPage;
    homeSearchButton.dataset.umamiEventTargetPage = targetPage;
  };
  homeSearchInput?.addEventListener('input', syncHomeSearchEvent);
  homeSearchForm?.addEventListener('submit', syncHomeSearchEvent);
  syncHomeSearchEvent();
</script>
