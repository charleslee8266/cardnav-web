---
/*
文件说明: 渲染 CardNav 公开首页，按卡片模块展示模型、订阅价格、热门产品和卡网商家入口。
*/
import PublicPage from '../layouts/PublicPage.astro';
import Sponsors from '../components/Sponsors.astro';
import { localizeModelLeaderboardGroups, localizeOfficialPriceGroups } from '../localized-display.js';
import { buildModelLeaderboardGroups } from '../model-leaderboard.js';
import { buildOfficialPriceGroups } from '../official-price.js';
import { buildSeoContext } from '../seo.js';
import { publicSiteUrl } from '../site.js';
import { loadDashboardData, loadModelLeaderboards, loadOfficialPrices, loadPopularSearchTerms } from '../store.js';

const t = Astro.locals.messages;
const linkTo = Astro.locals.localizePath;
const dashboardData = await loadDashboardData({ productLimit: 10 });
const leaderboardRows = await loadModelLeaderboards();
const officialPrices = await loadOfficialPrices();
const popularSearchTerms = (await loadPopularSearchTerms(10, [...t.home.presetPopularSearchTerms])).terms
  .map(term => term.trim())
  .filter(Boolean);

const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/',
  title: t.home.seoTitle,
  description: t.home.seoDescription,
  imagePath: '/og-cardnav.svg',
  type: 'website',
  locale: Astro.locals.locale,
});

const localizedLeaderboardGroups = localizeModelLeaderboardGroups(
  buildModelLeaderboardGroups(leaderboardRows).map(group => ({
    ...group,
    rows: group.rows.slice(0, 3),
  })),
  t,
);

const officialPriceGroups = localizeOfficialPriceGroups(
  buildOfficialPriceGroups(officialPrices),
  Astro.locals.locale,
)
  .slice(0, 3)
  .map(group => ({
    ...group,
    prices: group.prices.slice(0, 3),
  }));

const hotProducts = dashboardData.products.slice(0, 10).map(product => ({
  ...product,
  displayPrice: typeof product.priceNumber === 'number' && product.priceUnit
    ? `${product.priceUnit}${String(product.priceNumber)}`
    : product.price,
}));

const guideSteps: Array<{ title: string; href: string }> = [...t.home.guideSteps];

const guideSourcePage = '/';

function guideUrlClickAttrs(targetPage: string) {
  const localizedTargetPage = linkTo(targetPage);
  return {
    'data-umami-event': 'guide-url-click',
    'data-umami-event-source-page': linkTo(guideSourcePage),
    'data-umami-event-target-page': localizedTargetPage,
    'data-umami-event-url': localizedTargetPage,
  };
}

function homeCtaClickAttrs(targetPage: string, name: string) {
  const localizedTargetPage = linkTo(targetPage);
  return {
    'data-umami-event': 'home-cta-click',
    'data-umami-event-name': name,
    'data-umami-event-target-page': localizedTargetPage,
    'data-umami-event-url': localizedTargetPage,
  };
}

---

<PublicPage activeNav="home" showSponsors={false} {...seo}>
  <section class="card relative cursor-pointer bg-base-100 border border-base-300 shadow-sm overflow-hidden transition hover:border-primary/35 hover:shadow-md">
    <a href={linkTo('/guide')} class="absolute inset-0 z-0" aria-label={t.actions.openGuide} {...guideUrlClickAttrs('/guide')}></a>
    <div class="card-body p-4">
      <div class="pointer-events-none relative z-10 flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
        <div>
          <h2 class="text-xl font-bold text-base-content">{t.home.guideTitle}</h2>
          <p class="mt-1 text-sm leading-6 text-base-content/75">{t.home.guideDescription}</p>
        </div>
        <a href={linkTo('/guide')} class="pointer-events-auto btn btn-outline btn-sm shrink-0" {...guideUrlClickAttrs('/guide')}>{t.actions.openGuide}</a>
      </div>
      <div class="relative z-10 mt-3 grid gap-2 md:grid-cols-2 xl:grid-cols-4">
        {guideSteps.map((step, index) => (
          <a href={linkTo(step.href)} class="rounded-lg border border-base-300 bg-base-100 px-3 py-2 no-underline transition hover:border-primary/35 hover:bg-base-200/50" {...guideUrlClickAttrs(step.href)}>
            <span class="text-xs font-semibold text-primary">{t.home.stepLabel} {index + 1}</span>
            <span class="mt-1 block text-sm font-bold text-base-content">{step.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="grid gap-3 xl:grid-cols-3">
    <article class="order-2 card bg-base-100 border border-base-300 shadow-sm xl:order-1">
      <div class="card-body p-5">
        <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-xl font-bold text-base-content">{t.home.leaderboardTitle}</h2>
            <p class="text-sm leading-6 text-base-content/75">{t.home.leaderboardDescription}</p>
          </div>
          <a href={linkTo('/model-leaderboard')} class="btn btn-outline btn-sm shrink-0" {...homeCtaClickAttrs('/model-leaderboard', t.actions.viewFullLeaderboard)}>{t.actions.viewFullLeaderboard}</a>
        </div>
        <div class="mt-3 grid gap-3 md:grid-cols-2 xl:grid-cols-1">
          {localizedLeaderboardGroups.map(group => (
            <article class="rounded-2xl border border-base-300 bg-base-100 p-4">
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-lg font-bold text-base-content">{group.displayName}</h3>
                <span class="badge badge-ghost badge-sm font-medium">Top 3</span>
              </div>
              <div class="mt-3 space-y-3">
                {group.rows.map(item => (
                  <div class="flex items-center justify-between gap-3 rounded-xl bg-base-200/45 px-3 py-2">
                    <div class="min-w-0">
                      <p class="text-sm font-semibold text-base-content">#{item.rank} {item.modelName}</p>
                    </div>
                    <span class="text-sm font-mono font-bold text-primary">{item.score.toFixed(2)}</span>
                  </div>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </article>

    <article class="order-3 card bg-base-100 border border-base-300 shadow-sm xl:order-2">
      <div class="card-body p-5">
        <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-xl font-bold text-base-content">{t.home.officialPriceTitle}</h2>
            <p class="text-sm leading-6 text-base-content/75">{t.home.officialPriceDescription}</p>
          </div>
          <a href={linkTo('/official-price')} class="btn btn-outline btn-sm shrink-0" {...homeCtaClickAttrs('/official-price', t.actions.openPricePage)}>{t.actions.openPricePage}</a>
        </div>
        <div class="mt-3 space-y-3">
          {officialPriceGroups.map(group => (
            <section class="rounded-2xl border border-base-300 bg-base-100 p-4">
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-base font-bold text-base-content">{group.appName} {group.planName}</h3>
                <span class="badge badge-ghost badge-sm font-medium">{t.home.lowPriceRegions}</span>
              </div>
              <div class="mt-3 space-y-2">
                {group.prices.map((item, index) => (
                  <div class="flex items-center justify-between gap-3 rounded-xl bg-base-200/45 px-3 py-2">
                    <div class="min-w-0">
                      <p class="text-sm font-semibold text-base-content">#{index + 1} {item.localizedCountryLabel}</p>
                      <p class="text-xs text-base-content/65">{item.countryCode} · {item.priceText}</p>
                    </div>
                    <p class="min-w-16 text-right text-sm font-bold text-primary">{item.equivalentPriceText}</p>
                  </div>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </article>

    <article class="order-1 card bg-base-100 border border-base-300 shadow-sm xl:order-3">
      <div class="card-body p-5">
        <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-xl font-bold text-base-content">{t.home.hotProductsTitle}</h2>
            <p class="text-sm leading-6 text-base-content/75">{t.home.hotProductsDescription}</p>
          </div>
          <a href={linkTo('/shops')} class="btn btn-outline btn-sm shrink-0" {...homeCtaClickAttrs('/shops', t.actions.openShops)}>{t.actions.openShops}</a>
        </div>

        <div class="mt-3 space-y-3">
          <div class="collection-summary flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-base-content/70">
            <span>{t.labels.collectedSites}：<span class="font-bold text-primary">{dashboardData.totalSiteCount}</span></span>
            <span>{t.labels.products}：<span class="font-bold text-primary">{dashboardData.totalProductCount}</span></span>
            {dashboardData.latestRefreshTime && <span>{t.labels.latestRefresh}：{dashboardData.latestRefreshTime}</span>}
          </div>

          <form action={linkTo('/shops')} method="get" class="flex flex-col gap-3">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-center">
              <input name="q" type="search" class="input input-bordered w-full" placeholder={t.home.searchPlaceholder} autocomplete="off" />
              <button type="submit" class="btn btn-primary shrink-0" data-umami-event="home-search-submit" data-umami-event-name={t.analytics.homeSearch} data-umami-event-target-page={linkTo('/shops')}>{t.actions.search}</button>
            </div>
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-sm font-semibold text-base-content/65 uppercase tracking-wider">{t.labels.popularSearch}</span>
              {popularSearchTerms.map(term => (
                <a
                  href={`${linkTo('/shops')}?q=${encodeURIComponent(term)}`}
                  class="btn btn-outline btn-sm rounded-full border-base-300 font-semibold text-base-content/85 hover:text-base-content! hover:border-base-content/30! hover:bg-base-200!"
                  data-umami-event="home-hot-search-click"
                  data-umami-event-name={term}
                  data-umami-event-target-page={`${linkTo('/shops')}?q=${encodeURIComponent(term)}`}
                  data-umami-event-url={`${linkTo('/shops')}?q=${encodeURIComponent(term)}`}
                >
                  {term}
                </a>
              ))}
            </div>
          </form>

          <div class="space-y-2">
            {hotProducts.map(item => (
              <div class="flex items-center justify-between gap-3 rounded-xl bg-base-200/45 px-3 py-3">
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-base-content">{item.name}</p>
                  <p class="text-xs text-base-content/65">{item.siteName} · {item.categoryName}</p>
                </div>
                <div class="text-right">
                  <p class="text-sm font-bold text-primary">{item.displayPrice}</p>
                  <p class="text-xs text-base-content/60">{item.inStock ? t.labels.inStock : t.labels.soldOut}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </article>
  </section>

  <section class="grid gap-4 lg:grid-cols-2">
    <a href={linkTo('/tools')} class="card bg-base-100 border border-base-300 shadow-sm no-underline transition hover:-translate-y-0.5 hover:border-primary/35 hover:shadow-md" {...homeCtaClickAttrs('/tools', t.actions.openTools)}>
      <div class="card-body p-5">
        <span class="badge badge-ghost badge-sm w-fit font-medium">{t.home.practicalTools}</span>
        <h2 class="mt-2 text-xl font-bold text-base-content">{t.home.toolsTitle}</h2>
        <p class="mt-2 text-sm leading-6 text-base-content/75">{t.home.toolsDescription}</p>
        <span class="mt-4 text-sm font-semibold text-primary">{t.actions.openTools}</span>
      </div>
    </a>
    <a href={linkTo('/guide')} class="card bg-base-100 border border-base-300 shadow-sm no-underline transition hover:-translate-y-0.5 hover:border-primary/35 hover:shadow-md" {...guideUrlClickAttrs('/guide')}>
      <div class="card-body p-5">
        <span class="badge badge-ghost badge-sm w-fit font-medium">{t.home.buyingGuide}</span>
        <h2 class="mt-2 text-xl font-bold text-base-content">{t.home.continueGuideTitle}</h2>
        <p class="mt-2 text-sm leading-6 text-base-content/75">{t.home.continueGuideDescription}</p>
        <span class="mt-4 text-sm font-semibold text-primary">{t.home.continueGuide}</span>
      </div>
    </a>
  </section>

  <Sponsors />
</PublicPage>
