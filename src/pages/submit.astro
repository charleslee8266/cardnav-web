---
/*
文件说明: 渲染站点提交页面，并处理提交表单的前端校验与反馈展示。
*/
import PublicPage from '../layouts/PublicPage.astro';
import { buildSeoContext } from '../seo.js';
import { publicSiteUrl, telegramGroupUrl } from '../site.js';

const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/submit',
  title: '提交商家',
  description: '商家可提交站点 URL 入驻卡网大全，也可通过 Telegram 联系合作，获得更多曝光入口。',
  imagePath: '/og-cardnav.svg',
  type: 'webpage',
});
---

<PublicPage activeNav="submit" {...seo}>
  <section class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body p-5">
      <div class="page-hero-wrap">
        <h2 class="page-hero-title mt-0">提交商家</h2>
        <p class="page-hero-copy">提交后，系统将自动识别并收录支持的站点，其余类型将转为人工尽快审核，请勿重复提交。</p>
      </div>
      
      <div class="alert alert-info alert-soft shadow-sm mt-4 flex flex-col items-start gap-1.5 text-left text-base-content">
        <span class="font-bold text-sm">合作曝光</span>
        <p class="text-sm text-base-content/85 leading-6">商家如有合作意向，可以在卡网大全获得更高曝光，例如赞助位、重点展示或更多入口推荐。具体合作方式请通过 Telegram 联系。</p>
        <a href={telegramGroupUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm mt-2 inline-flex items-center gap-2">
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="h-4 w-4 shrink-0" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m22 2-7 20-4-9-9-4Z"></path>
            <path d="M22 2 11 13"></path>
          </svg>
          Telegram 联系
        </a>
      </div>
      
      <form id="submitForm" class="form-control gap-3 mt-4" method="post" action="/api/submit">
        <div>
          <label for="urlInput" class="label font-semibold text-sm pb-1">URL</label>
          <input id="urlInput" name="url" type="url" required value="" class="input input-bordered w-full" placeholder="https://example.com" autocomplete="url" />
        </div>
        <p id="clientError" class="hidden text-sm text-error font-medium">请输入有效的 URL</p>
        <p id="submitError" class="hidden text-sm text-error font-medium"></p>
        <p id="submitSuccess" class="hidden text-sm text-success font-medium"></p>
        <div class="card-actions justify-start mt-2">
          <button type="submit" data-umami-event="submit-click" data-umami-event-url="" class="btn btn-primary">
            提交
          </button>
        </div>
      </form>
    </div>
  </section>

  <script slot="scripts" is:inline>
    const form = document.querySelector('#submitForm');
    const input = document.querySelector('#urlInput');
    const clientError = document.querySelector('#clientError');
    const submitError = document.querySelector('#submitError');
    const submitSuccess = document.querySelector('#submitSuccess');
    const submitButton = form.querySelector('button[type="submit"]');

    function syncSubmitEventUrl() {
      submitButton.dataset.umamiEventUrl = input.value.trim();
    }

    function isValidUrl(value) {
      try {
        const url = new URL(value.trim());
        return url.protocol === 'http:' || url.protocol === 'https:';
      } catch {
        return false;
      }
    }

    function hideServerMessages() {
      submitError.classList.add('hidden');
      submitSuccess.classList.add('hidden');
      submitError.textContent = '';
      submitSuccess.textContent = '';
    }

    function showError(message) {
      submitSuccess.classList.add('hidden');
      submitSuccess.textContent = '';
      submitError.textContent = message;
      submitError.classList.remove('hidden');
    }

    function showSuccess(message) {
      submitError.classList.add('hidden');
      submitError.textContent = '';
      submitSuccess.textContent = message;
      submitSuccess.classList.remove('hidden');
    }

    form.addEventListener('submit', event => {
      syncSubmitEventUrl();
      hideServerMessages();
      if (!isValidUrl(input.value)) {
        event.preventDefault();
        clientError.classList.remove('hidden');
        input.focus();
        return;
      }

      event.preventDefault();
      clientError.classList.add('hidden');
      submitButton.disabled = true;

      fetch(form.action, {
        method: 'POST',
        body: JSON.stringify({ url: input.value.trim() }),
        headers: {
          accept: 'application/json',
          'content-type': 'application/json',
          'x-requested-with': 'fetch',
        },
      })
        .then(async response => {
          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload || payload.ok !== true) {
            showError(payload && payload.message ? payload.message : '提交失败，请稍后重试');
            return;
          }
          input.value = '';
          syncSubmitEventUrl();
          showSuccess(payload.message || '提交成功');
        })
        .catch(() => {
          showError('提交失败，请稍后重试');
        })
        .finally(() => {
          submitButton.disabled = false;
        });
    });

    input.addEventListener('input', () => {
      syncSubmitEventUrl();
      clientError.classList.add('hidden');
      hideServerMessages();
    });

    syncSubmitEventUrl();
  </script>
</PublicPage>
