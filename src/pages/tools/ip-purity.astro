---
/*
文件说明: 渲染 IP 纯净度工具页，提供 IP 输入、自动识别、纯净度评分和多源风险信号
*/
import PublicPage from '../../layouts/PublicPage.astro';
import { buildSeoContext } from '../../seo.js';
import { publicSiteUrl } from '../../site.js';

const linkTo = Astro.locals.localizePath;
const t = Astro.locals.messages;
const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/tools/ip-purity',
  title: t.ipPurity.seoTitle,
  description: t.ipPurity.seoDescription,
  imagePath: '/og-cardnav.png',
  type: 'webpage',
  locale: Astro.locals.locale,
});
---

<PublicPage activeNav="ip-purity" showSponsors={false} {...seo}>
  <section class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body p-5">
      <div class="page-hero-wrap">
        <h1 class="page-hero-title">{t.ipPurity.title}</h1>
        <p class="page-hero-copy">{t.ipPurity.description}</p>
        <div class="mt-4">
          <a href={linkTo('/guide/tool-ip-check')} data-umami-event="guide-url-click" data-umami-event-source-page={linkTo('/tools/ip-purity')} data-umami-event-target-page={linkTo('/guide/tool-ip-check')} data-umami-event-url={linkTo('/guide/tool-ip-check')} class="link link-primary text-sm font-semibold">{t.ipPurity.guideLink}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="ip-purity-grid grid gap-4 xl:grid-cols-[1.05fr_0.95fr]">
    <section class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden">
      <div class="bg-base-200 px-5 py-4 border-b border-base-300">
        <div class="flex flex-col gap-2 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <h3 class="text-base font-bold text-base-content">{t.ipPurity.inputTitle}</h3>
          </div>
        </div>
      </div>
      <div class="card-body p-5">
        <form id="ipPurityForm" class="flex flex-col gap-3" novalidate>
          <label for="ipPurityInput" class="text-sm font-semibold text-base-content">{t.ipPurity.ipAddress}</label>
          <div class="flex flex-col gap-2 md:flex-row">
            <input id="ipPurityInput" class="input input-bordered w-full font-mono" type="text" inputmode="text" autocomplete="off" placeholder={t.ipPurity.inputPlaceholder} />
            <button id="ipPuritySubmit" class="btn btn-primary md:min-w-28" type="submit">{t.ipPurity.startCheck}</button>
          </div>
          <div class="flex flex-wrap gap-2">
            <button id="ipPurityDetectCurrent" class="btn btn-sm btn-outline btn-primary" type="button">{t.ipPurity.detectCurrent}</button>
            <button id="ipPurityClear" class="btn btn-sm btn-outline" type="button">{t.ipPurity.clear}</button>
          </div>
          <p id="ipPurityStatus" class="tool-status-line text-sm text-base-content/75">{t.ipPurity.initialStatus}</p>
        </form>

        <div id="ipPurityError" class="alert alert-error shadow-sm text-sm hidden"></div>

        <div class="grid gap-3 md:grid-cols-3">
          <article class="card bg-base-200 border border-base-300 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-base-content/55">{t.ipPurity.purity}</p>
            <div class="mt-2 flex items-end gap-2">
              <strong id="ipPurityScore" class="text-4xl font-bold leading-none text-base-content">--</strong>
              <span class="pb-1 text-base-content/60">/ 100</span>
            </div>
            <span id="ipPurityBadge" class="badge badge-ghost mt-3 w-fit">{t.ipPurity.waiting}</span>
          </article>
          <article class="card bg-base-200 border border-base-300 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-base-content/55">{t.ipPurity.checkedIp}</p>
            <p id="ipPurityIp" class="mt-3 break-all font-mono text-lg font-semibold text-base-content">--</p>
            <p id="ipPurityCheckedAt" class="mt-2 text-xs text-base-content/60">--</p>
          </article>
          <article class="card bg-base-200 border border-base-300 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-base-content/55">{t.ipPurity.summary}</p>
            <p id="ipPuritySummary" class="mt-3 text-sm leading-6 text-base-content/80">{t.ipPurity.emptySummary}</p>
          </article>
        </div>
      </div>
    </section>

    <section class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden">
      <div class="bg-base-200 px-5 py-4 border-b border-base-300">
        <h3 class="text-base font-bold text-base-content">{t.ipPurity.networkInfo}</h3>
      </div>
      <div class="card-body p-5">
        <div class="grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
          <dl class="ip-purity-facts-grid">
            <div class="ip-purity-fact-card">
              <dt>{t.ipPurity.countryRegion}</dt>
              <dd id="ipPurityCountry">--</dd>
            </div>
            <div class="ip-purity-fact-card">
              <dt>{t.ipPurity.region}</dt>
              <dd id="ipPurityRegion">--</dd>
            </div>
            <div class="ip-purity-fact-card">
              <dt>{t.ipPurity.city}</dt>
              <dd id="ipPurityCity">--</dd>
            </div>
            <div class="ip-purity-fact-card">
              <dt>ISP</dt>
              <dd id="ipPurityIsp">--</dd>
            </div>
            <div class="ip-purity-fact-card">
              <dt>{t.ipPurity.organization}</dt>
              <dd id="ipPurityOrg">--</dd>
            </div>
            <div class="ip-purity-fact-card">
              <dt>ASN</dt>
              <dd id="ipPurityAsn">--</dd>
            </div>
            <div class="ip-purity-fact-card">
              <dt>{t.ipPurity.networkType}</dt>
              <dd id="ipPurityNetworkType">--</dd>
            </div>
            <div class="ip-purity-fact-card">
              <dt>{t.ipPurity.coordinates}</dt>
              <dd id="ipPurityCoordinates">--</dd>
            </div>
          </dl>

          <section class="ip-purity-map-card" aria-labelledby="ipPurityMapTitle">
            <div>
              <div>
                <h4 id="ipPurityMapTitle" class="text-sm font-bold text-base-content">{t.ipPurity.mapTitle}</h4>
                <p id="ipPurityMapCaption" class="mt-1 text-xs leading-5 text-base-content/60">{t.ipPurity.mapCaption}</p>
              </div>
            </div>
            <div id="ipPurityMap" class="ip-purity-map" role="img" aria-label={t.ipPurity.mapAria}></div>
          </section>
        </div>
      </div>
    </section>
  </section>

  <section class="grid gap-4 xl:grid-cols-[1.05fr_0.95fr]">
    <section class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden">
      <div class="bg-base-200 px-5 py-4 border-b border-base-300">
        <h3 class="text-base font-bold text-base-content">{t.ipPurity.signals}</h3>
      </div>
      <div class="card-body p-5">
        <div id="ipPuritySignals" class="ip-purity-signals"></div>
      </div>
    </section>

    <section class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden">
      <div class="bg-base-200 px-5 py-4 border-b border-base-300">
        <h3 class="text-base font-bold text-base-content">{t.ipPurity.sources}</h3>
      </div>
      <div class="card-body p-5">
        <div id="ipPuritySources" class="ip-purity-sources"></div>
      </div>
    </section>
  </section>

  <section class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body p-5">
      <div class="page-hero-wrap">
        <h3 class="text-lg font-bold text-base-content">{t.ipPurity.explainTitle}</h3>
        <p class="page-hero-copy">{t.ipPurity.explainDescription}</p>
      </div>
    </div>
  </section>

  <section class="grid gap-4 xl:grid-cols-3">
    <article class="card bg-base-100 border border-base-300 shadow-sm">
      <div class="card-body p-5">
        <h3 class="text-base font-bold text-base-content">{t.ipPurity.focusTitle}</h3>
        <p class="mt-2 text-sm leading-6 text-base-content/78">{t.ipPurity.focusDescription}</p>
      </div>
    </article>
    <article class="card bg-base-100 border border-base-300 shadow-sm">
      <div class="card-body p-5">
        <h3 class="text-base font-bold text-base-content">{t.ipPurity.cautionTitle}</h3>
        <p class="mt-2 text-sm leading-6 text-base-content/78">{t.ipPurity.cautionDescription}</p>
      </div>
    </article>
    <article class="card bg-base-100 border border-base-300 shadow-sm">
      <div class="card-body p-5">
        <h3 class="text-base font-bold text-base-content">{t.ipPurity.notFinalTitle}</h3>
        <p class="mt-2 text-sm leading-6 text-base-content/78">{t.ipPurity.notFinalDescription}</p>
      </div>
    </article>
  </section>

</PublicPage>

<script is:inline type="application/json" id="ip-purity-runtime-dict" set:html={JSON.stringify(t.ipPurity.runtime)}></script>
<script>
  import '../../scripts/ip-purity.js';
</script>
