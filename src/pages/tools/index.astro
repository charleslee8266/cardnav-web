---
/*
文件说明: 渲染 CardNav 公开工具集合页，作为多个小工具的统一入口。
*/
import PublicPage from '../../layouts/PublicPage.astro';
import { buildSeoContext } from '../../seo.js';
import { publicSiteUrl } from '../../site.js';

const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/tools',
  title: '工具集',
  description: '卡网大全工具提供和 AI 账号、订阅、导入格式相关的小工具，帮助用户在浏览器本地完成常用转换。',
  imagePath: '/og-cardnav.svg',
  type: 'webpage',
});
---

<PublicPage activeNav="tools" {...seo}>
  <section class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body p-5">
      <div class="page-hero-wrap">
        <p class="page-hero-kicker">CardNav 工具集</p>
        <h2 class="page-hero-title">常用账号与订阅格式转换工具</h2>
        <p class="page-hero-copy">工具默认在浏览器本地处理输入内容，适合临时转换、核对和导出 JSON。</p>
      </div>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-2">
    <article class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md hover:border-primary/50 transition-all p-5">
      <a href="/tools/session-converter" class="block">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="text-lg font-bold text-base-content">Session 转换工具</h3>
          <span class="badge badge-ghost badge-sm font-medium">本地转换</span>
        </div>
        <p class="mt-2 text-sm leading-6 text-base-content/75">把 ChatGPT Web session、CPA、Sub2API、Cockpit、Codex auth.json、9Router OAuth JSON 等转换成 CPA、Sub2API、Cockpit、Codex、AxonHub 或 Codex-Manager 可导入 JSON。</p>
        <div class="mt-4 link link-primary font-semibold text-sm">打开工具 ➜</div>
      </a>
    </article>

    <article class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md hover:border-primary/50 transition-all p-5">
      <a href="https://codex.kedaya.xyz/" target="_blank" rel="noopener noreferrer" class="block">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="text-lg font-bold text-base-content">Codex 凭证助手</h3>
          <span class="badge badge-ghost badge-sm font-medium">外部网站</span>
        </div>
        <p class="mt-2 text-sm leading-6 text-base-content/75">通过账号密码导入账号，并按目标格式导出 Codex 凭证数据。</p>
        <p class="mt-2 text-xs leading-5 text-error font-medium">此工具来自外部网站，非本站提供，请自行承担使用风险。</p>
        <div class="mt-4 link link-primary font-semibold text-sm">打开外部工具 ➜</div>
      </a>
    </article>

    <article class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md hover:border-primary/50 transition-all p-5">
      <a href="https://mail.chatai.codes/" target="_blank" rel="noopener noreferrer" class="block">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="text-lg font-bold text-base-content">Outlook 快速取件</h3>
          <span class="badge badge-ghost badge-sm font-medium">外部网站</span>
        </div>
        <p class="mt-2 text-sm leading-6 text-base-content/75">通过 IMAP OAuth2 和 Graph API 查询 Outlook 邮件，适合临时搜索和取件。</p>
        <p class="mt-2 text-xs leading-5 text-error font-medium">此工具来自外部网站，非本站提供，请自行承担使用风险。</p>
        <div class="mt-4 link link-primary font-semibold text-sm">打开外部工具 ➜</div>
      </a>
    </article>
  </section>
</PublicPage>
