---
/*
文件说明: 渲染 CardNav 公开工具集合页，作为多个小工具的统一入口。
*/
import PublicPage from '../../layouts/PublicPage.astro';
import { buildSeoContext } from '../../seo.js';
import { publicSiteUrl } from '../../site.js';

const linkTo = Astro.locals.localizePath;
const t = Astro.locals.messages;
const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/tools',
  title: t.tools.seoTitle,
  description: t.tools.seoDescription,
  imagePath: '/og-cardnav.svg',
  type: 'webpage',
  locale: Astro.locals.locale,
});
---

<PublicPage activeNav="tools" {...seo}>
  <section class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body p-5">
      <div class="page-hero-wrap">
        <h1 class="page-hero-title">{t.tools.title}</h1>
        <p class="page-hero-copy">{t.tools.description}</p>
      </div>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-2">
    <article class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md hover:border-primary/50 transition-all p-5">
      <a href={linkTo('/tools/session-converter')} data-umami-event="tool-entry-click" data-umami-event-name={t.tools.sessionConverter.title} data-umami-event-target-page={linkTo('/tools/session-converter')} data-umami-event-url={linkTo('/tools/session-converter')} class="block">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="text-lg font-bold text-base-content">{t.tools.sessionConverter.title}</h3>
          <span class="badge badge-ghost badge-sm font-medium">{t.labels.localConvert}</span>
        </div>
        <p class="mt-2 text-sm leading-6 text-base-content/75">{t.tools.sessionConverter.description}</p>
        <div class="mt-4 link link-primary font-semibold text-sm">{t.actions.openTool} ➜</div>
      </a>
    </article>

    <article class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md hover:border-primary/50 transition-all p-5">
      <a href={linkTo('/tools/ip-purity')} data-umami-event="tool-entry-click" data-umami-event-name={t.tools.ipPurity.title} data-umami-event-target-page={linkTo('/tools/ip-purity')} data-umami-event-url={linkTo('/tools/ip-purity')} class="block">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="text-lg font-bold text-base-content">{t.tools.ipPurity.title}</h3>
          <span class="badge badge-ghost badge-sm font-medium">{t.labels.onlineCheck}</span>
        </div>
        <p class="mt-2 text-sm leading-6 text-base-content/75">{t.tools.ipPurity.description}</p>
        <div class="mt-4 link link-primary font-semibold text-sm">{t.actions.openTool} ➜</div>
      </a>
    </article>

    <article class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md hover:border-primary/50 transition-all p-5">
      <a href="https://codex.kedaya.xyz/" target="_blank" rel="noopener noreferrer" data-umami-event="tool-entry-click" data-umami-event-name={t.tools.codexHelper.title} data-umami-event-url="https://codex.kedaya.xyz/" class="block">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="text-lg font-bold text-base-content">{t.tools.codexHelper.title}</h3>
          <span class="badge badge-ghost badge-sm font-medium">{t.labels.externalSite}</span>
        </div>
        <p class="mt-2 text-sm leading-6 text-base-content/75">{t.tools.codexHelper.description}</p>
        <p class="mt-2 text-xs leading-5 text-error font-medium">{t.tools.externalRisk}</p>
        <div class="mt-4 link link-primary font-semibold text-sm">{t.actions.openExternalTool} ➜</div>
      </a>
    </article>

    <article class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md hover:border-primary/50 transition-all p-5">
      <a href="https://mail.chatai.codes/" target="_blank" rel="noopener noreferrer" data-umami-event="tool-entry-click" data-umami-event-name={t.tools.outlookMail.title} data-umami-event-url="https://mail.chatai.codes/" class="block">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="text-lg font-bold text-base-content">{t.tools.outlookMail.title}</h3>
          <span class="badge badge-ghost badge-sm font-medium">{t.labels.externalSite}</span>
        </div>
        <p class="mt-2 text-sm leading-6 text-base-content/75">{t.tools.outlookMail.description}</p>
        <p class="mt-2 text-xs leading-5 text-error font-medium">{t.tools.externalRisk}</p>
        <div class="mt-4 link link-primary font-semibold text-sm">{t.actions.openExternalTool} ➜</div>
      </a>
    </article>
  </section>
</PublicPage>
