---
/*
文件说明: 渲染 CardNav 公开工具集合页，作为多个小工具的统一入口。
*/
import PublicPage from '../../layouts/PublicPage.astro';
import { buildSeoContext } from '../../seo.js';
import { publicSiteUrl } from '../../site.js';

const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/tools',
  title: '工具集',
  description: '卡网大全工具提供和 AI 账号、订阅、导入格式相关的小工具，帮助用户在浏览器本地完成常用转换。',
  imagePath: '/og-cardnav.svg',
  type: 'webpage',
});
---

<PublicPage activeNav="tools" {...seo}>
  <section class="content-panel">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold text-blue-700">卡网大全工具</p>
      <h2 class="mt-1 text-2xl font-bold tracking-normal text-slate-950">常用账号与订阅格式转换工具</h2>
      <p class="mt-2 text-sm leading-6 text-slate-600">工具默认在浏览器本地处理输入内容，适合临时转换、核对和导出 JSON。</p>
    </div>
  </section>

  <section class="grid gap-3 md:grid-cols-2">
    <article class="tool-card">
      <a href="/tools/session-converter" class="block">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="text-lg font-semibold tracking-normal text-slate-950">Session 转换工具</h3>
          <span class="neutral-badge">本地转换</span>
        </div>
        <p class="mt-2 text-sm leading-6 text-slate-600">把 ChatGPT Web session、Codex auth.json、9Router OAuth JSON 等转换成 CPA、Sub2API、Cockpit、Codex、AxonHub 或 Codex-Manager 可导入 JSON。</p>
        <span class="mt-3 inline-flex text-sm font-semibold text-blue-700">打开工具</span>
      </a>
    </article>

    <article class="tool-card">
      <a href="https://codex.kedaya.xyz/" target="_blank" rel="noopener noreferrer" class="block">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="text-lg font-semibold tracking-normal text-slate-950">Codex 凭证助手</h3>
          <span class="neutral-badge">外部网站</span>
        </div>
        <p class="mt-2 text-sm leading-6 text-slate-600">通过账号密码导入账号，并按目标格式导出 Codex 凭证数据。</p>
        <p class="mt-2 text-xs leading-5 text-red-700">此工具来自外部网站，非本站提供，请自行承担使用风险。</p>
        <span class="mt-3 inline-flex text-sm font-semibold text-blue-700">打开外部工具</span>
      </a>
    </article>

    <article class="tool-card">
      <a href="https://mail.chatai.codes/" target="_blank" rel="noopener noreferrer" class="block">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="text-lg font-semibold tracking-normal text-slate-950">Outlook 快速取件</h3>
          <span class="neutral-badge">外部网站</span>
        </div>
        <p class="mt-2 text-sm leading-6 text-slate-600">通过 IMAP OAuth2 和 Graph API 查询 Outlook 邮件，适合临时搜索和取件。</p>
        <p class="mt-2 text-xs leading-5 text-red-700">此工具来自外部网站，非本站提供，请自行承担使用风险。</p>
        <span class="mt-3 inline-flex text-sm font-semibold text-blue-700">打开外部工具</span>
      </a>
    </article>
  </section>
</PublicPage>
