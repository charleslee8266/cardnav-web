---
/*
文件说明: 渲染 Session 转换工具页，承载本地 JSON 输入、输出格式选择、预览、复制和下载操作。
参考资料: GPTSession2CPAandSub2API 行为逻辑
*/
import PublicPage from '../../layouts/PublicPage.astro';
import { buildSeoContext } from '../../seo.js';
import highlightScriptUrl from '@highlightjs/cdn-assets/highlight.min.js?url';
import highlightCssUrl from '@highlightjs/cdn-assets/styles/github.min.css?url';
import highlightDarkCssUrl from '@highlightjs/cdn-assets/styles/github-dark.min.css?url';
import sessionConverterScriptUrl from '../../scripts/session-converter.js?url';
import { publicSiteUrl } from '../../site.js';

const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/tools/session-converter',
  title: 'Session 转换工具',
  description: '把 ChatGPT Web session、CPA、Sub2API、Cockpit、Codex auth.json、9Router OAuth JSON 等本地转换为 CPA、Sub2API、Cockpit、9Router、Codex、AxonHub 或 Codex-Manager 可导入 JSON。',
  imagePath: '/og-cardnav.svg',
  type: 'webpage',
});
---

<PublicPage activeNav="tools" showSponsors={false} {...seo}>
  <link slot="head" id="hljs-theme" rel="stylesheet" href={highlightCssUrl} data-light={highlightCssUrl} data-dark={highlightDarkCssUrl} />

  <section class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body p-5">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div class="page-hero-wrap flex-1">
          <h2 class="page-hero-title mt-0">ChatGPT Session 转换工具</h2>
          <p class="page-hero-copy">浏览器本地处理，支持把 ChatGPT Session、CPA、Sub2API、Cockpit、Codex、9Router、AxonHub、Codex-Manager 等常见 JSON 转成目标导入格式。</p>
        </div>
        <div class="alert border border-error/20 dark:border-error/30 bg-error/5 py-2 px-3 rounded-md text-left text-xs font-semibold text-error lg:max-w-xl shrink-0">
          <span class="leading-relaxed">Session/Token 等均属敏感凭证，仅建议在自己设备上处理；请确认数据来自您掌握的账号。</span>
        </div>
      </div>
    </div>
  </section>

  <section class="session-converter-grid grid gap-4 xl:grid-cols-2">
    <section class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden" aria-labelledby="session-input-title">
      <div class="bg-base-200 px-5 py-4 border-b border-base-300">
        <div>
          <h3 id="session-input-title" class="text-base font-bold text-base-content">凭证 JSON</h3>
          <p class="mt-1 text-sm text-base-content/75">支持格式：ChatGPT Web session / CPA / Cockpit / Sub2API / 9Router OAuth JSON / Codex auth.json / AxonHub auth.json / Codex-Manager JSON</p>
        </div>
      </div>
      <div class="card-body p-5">
        <div class="alert alert-info alert-soft shadow-sm p-4 text-sm text-left text-base-content">
          <div>
            <p class="font-bold">Session 数据获取入口</p>
            <p class="mt-1 text-sm text-base-content/85">登录 ChatGPT 后打开 <a href="https://chatgpt.com/api/auth/session" target="_blank" rel="noopener noreferrer" class="link link-primary font-bold">https://chatgpt.com/api/auth/session</a>，复制整段 JSON 后粘贴到下方。</p>
          </div>
        </div>
        <input id="sessionFileInput" class="hidden" type="file" accept=".json,application/json" multiple />
        <div class="mt-3 flex flex-wrap gap-2">
          <button id="sessionPickFiles" class="btn btn-sm btn-outline btn-primary" type="button">选择文件</button>
          <button id="sessionLoadExample" class="btn btn-sm btn-outline btn-primary" type="button">填入示例</button>
          <button id="sessionClearInput" class="btn btn-sm btn-outline btn-error" type="button">清空</button>
        </div>
        <textarea id="sessionInput" class="session-converter-textarea tool-json-textarea textarea textarea-bordered w-full mt-3 h-96 font-mono text-sm leading-6" spellcheck="false" placeholder='{"user":{"email":"mark@example.com"},"expires":"2026-08-06T14:29:36.155Z","account":{"id":"...","planType":"plus"},"accessToken":"...","sessionToken":"..."}'></textarea>
      </div>
    </section>

    <section class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden" aria-labelledby="session-output-title">
      <div class="bg-base-200 px-5 py-4 border-b border-base-300">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <h3 id="session-output-title" class="text-base font-bold text-base-content">转换结果</h3>
            <p id="sessionOutputSubtitle" class="mt-1 text-sm text-base-content/75">当前输出为 Sub2API 导入 JSON。</p>
          </div>
          <div class="flex flex-wrap gap-2">
            <button id="sessionCopyOutput" class="btn btn-sm btn-outline btn-primary" type="button" disabled>复制输出</button>
            <button id="sessionDownloadOutput" class="btn btn-sm btn-primary" type="button" disabled>下载 JSON</button>
          </div>
        </div>
      </div>
      <div class="card-body p-5">
        <div id="sessionTokenNotice" class="alert alert-warning alert-soft shadow-sm mb-3 flex-none text-left text-sm leading-6 text-base-content">
          <span>ChatGPT Web session 通常没有 refresh_token。缺少真实 id_token 时，CPA、Cockpit、Codex 和 AxonHub 会生成可解析的占位 JWT claims；AxonHub 缺少真实 refresh_token 时会写入占位值。</span>
        </div>
        <div class="grid gap-2 sm:grid-cols-3 flex-none">
          <div class="card bg-base-200 border border-base-300 p-3 justify-center">
            <select id="sessionFormatSelect" class="select select-bordered select-sm w-full font-bold bg-base-100" aria-label="输出格式">
              <option value="Sub2API" selected>Sub2API</option>
              <option value="cpa">CPA</option>
              <option value="cockpit">Cockpit</option>
              <option value="9Router">9Router</option>
              <option value="codex">Codex</option>
              <option value="axonhub">AxonHub</option>
              <option value="codexmanager">Codex-Manager</option>
            </select>
            <div class="text-xs font-semibold text-base-content/70 uppercase mt-1">输出格式</div>
          </div>
          <div class="card bg-base-200 border border-base-300 p-3">
            <div id="sessionStatCount" class="font-bold text-2xl font-mono text-base-content leading-none">0</div>
            <div class="text-xs font-semibold text-base-content/70 uppercase mt-1">账号数</div>
          </div>
          <div class="card bg-base-200 border border-base-300 p-3">
            <div id="sessionStatErrors" class="font-bold text-2xl font-mono text-base-content leading-none">0</div>
            <div class="text-xs font-semibold text-base-content/70 uppercase mt-1">跳过项</div>
          </div>
        </div>
        <div class="session-account-table mt-3 overflow-hidden rounded-lg border border-base-300 bg-base-100">
          <div class="max-h-56 overflow-auto">
            <table class="table table-xs table-zebra w-full text-sm">
              <thead class="sticky top-0 bg-base-200 text-sm font-bold text-base-content">
                <tr>
                  <th class="w-[30%] text-left">名称</th>
                  <th class="w-[42%] text-left">邮箱</th>
                  <th class="w-[28%] text-left">过期时间</th>
                </tr>
              </thead>
              <tbody id="sessionAccountRows">
                <tr>
                  <td colspan="3" class="text-center py-4 text-sm text-base-content/40">暂无可转换账号。</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        <div id="sessionIssues" class="tool-issues mt-3 alert alert-error shadow-sm text-sm hidden flex-none"></div>
        <pre class="session-converter-textarea tool-code-output mt-3 p-4 border border-base-300 hljs overflow-auto rounded-lg font-mono text-sm leading-6"><code id="sessionOutput" class="language-json"></code></pre>
        <p id="sessionOutputStatus" class="tool-status-line mt-2 text-xs font-semibold"></p>
      </div>
    </section>
  </section>

  <script is:inline slot="scripts" defer src={highlightScriptUrl}></script>
  <script is:inline slot="scripts" defer src={sessionConverterScriptUrl}></script>
  <script is:inline slot="scripts">
    (function() {
      const link = document.getElementById('hljs-theme');
      if (!link) return;
      const lightUrl = link.getAttribute('data-light');
      const darkUrl = link.getAttribute('data-dark');
      
      function updateTheme() {
        const theme = document.documentElement.getAttribute('data-theme');
        const isDark = theme === 'dark';
        link.setAttribute('href', isDark ? darkUrl : lightUrl);
      }
      
      updateTheme();
      
      const observer = new MutationObserver(updateTheme);
      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme']
      });
    })();
  </script>
</PublicPage>
