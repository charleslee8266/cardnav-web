---
/*
文件说明: 渲染 Session 转换工具页，承载本地 JSON 输入、输出格式选择、预览、复制和下载操作。
参考资料: GPTSession2CPAandSub2API 行为逻辑
*/
import PublicPage from '../../layouts/PublicPage.astro';
import { buildSeoContext } from '../../seo.js';
import highlightScriptUrl from '@highlightjs/cdn-assets/highlight.min.js?url';
import highlightCssUrl from '@highlightjs/cdn-assets/styles/github.min.css?url';
import sessionConverterScriptUrl from '../../scripts/session-converter.js?url';
import { publicSiteUrl } from '../../site.js';

const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/tools/session-converter',
  title: 'Session 转换工具',
  description: '把 ChatGPT Web session、Codex auth.json、9Router OAuth JSON 等本地转换为 CPA、Sub2API、Cockpit、9Router、Codex、AxonHub 或 Codex-Manager 可导入 JSON。',
  imagePath: '/og-cardnav.svg',
  type: 'webpage',
});
---

<PublicPage activeNav="tools" showSponsors={false} {...seo}>
  <link slot="head" rel="stylesheet" href={highlightCssUrl} />

  <section class="content-panel">
    <div>
      <h2 class="mt-1 text-2xl font-bold tracking-normal text-slate-950">ChatGPT Session 转换工具</h2>
      <p class="mt-2 text-sm leading-6 text-slate-600">粘贴或导入 JSON，在浏览器本地转换为 CPA、Sub2API、Cockpit、9Router、Codex、AxonHub 或 Codex-Manager 格式。</p>
      <p class="mt-3 rounded border border-red-200 bg-red-50 px-3 py-2 text-sm font-semibold leading-6 text-red-700">Session、access_token、refresh_token 都属于敏感凭证，只建议在自己的设备上临时处理；转换前请确认输入内容来自你自己掌握的账号。</p>
    </div>
  </section>

  <section class="session-converter-grid grid gap-4 xl:grid-cols-2">
    <section class="tool-panel" aria-labelledby="session-input-title">
      <div class="tool-panel-head">
        <div>
          <h3 id="session-input-title" class="text-base font-semibold text-slate-950">Session JSON</h3>
          <p class="mt-1 text-sm leading-6 text-slate-600">支持格式：ChatGPT Web session / 9 Router OAuth JSON / Codex auth.json / AxonHub auth.json / Codex-Manager JSON</p>
        </div>
      </div>
      <div class="tool-panel-body">
        <div class="rounded border border-blue-200 bg-blue-50 p-4 text-sm leading-6 text-slate-700">
          <p class="font-semibold text-blue-950">Session 数据获取入口</p>
          <p class="mt-1">登录 ChatGPT 后打开 <a href="https://chatgpt.com/api/auth/session" target="_blank" rel="noopener noreferrer" class="font-semibold text-blue-700 hover:underline">https://chatgpt.com/api/auth/session</a>，复制整段 JSON 后粘贴到下方。</p>
        </div>
        <input id="sessionFileInput" class="hidden" type="file" accept=".json,application/json" multiple />
        <div class="mt-3 flex flex-wrap gap-2">
          <button id="sessionPickFiles" class="secondary-button" type="button">选择文件</button>
          <button id="sessionLoadExample" class="secondary-button" type="button">填入示例</button>
          <button id="sessionClearInput" class="compact-secondary-button" type="button">清空</button>
        </div>
        <textarea id="sessionInput" class="session-converter-textarea tool-json-textarea mt-3" spellcheck="false" placeholder='{"user":{"email":"mark@example.com"},"expires":"2026-08-06T14:29:36.155Z","account":{"id":"...","planType":"plus"},"accessToken":"...","sessionToken":"..."}'></textarea>
      </div>
    </section>

    <section class="tool-panel" aria-labelledby="session-output-title">
      <div class="tool-panel-head">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <h3 id="session-output-title" class="text-base font-semibold text-slate-950">转换结果</h3>
            <p id="sessionOutputSubtitle" class="mt-1 text-sm leading-6 text-slate-600">当前输出为 Sub2API 导入 JSON。</p>
          </div>
          <div class="flex flex-wrap gap-2">
            <button id="sessionCopyOutput" class="secondary-button" type="button" disabled>复制输出</button>
            <button id="sessionDownloadOutput" class="primary-button" type="button" disabled>下载 JSON</button>
          </div>
        </div>
      </div>
      <div class="tool-panel-body">
        <p id="sessionTokenNotice" class="mb-3 rounded border border-amber-200 bg-amber-50 px-3 py-2 text-sm leading-6 text-amber-800">
          ChatGPT Web session 通常没有 refresh_token。缺少真实 id_token 时，CPA、Cockpit、Codex 和 AxonHub 会生成可解析的占位 JWT claims；AxonHub 缺少真实 refresh_token 时会写入占位值。
        </p>
        <div class="grid gap-2 sm:grid-cols-3">
          <div class="tool-stat">
            <select id="sessionFormatSelect" class="tool-format-select" aria-label="输出格式">
              <option value="Sub2API" selected>Sub2API</option>
              <option value="cpa">CPA</option>
              <option value="cockpit">Cockpit</option>
              <option value="9Router">9Router</option>
              <option value="codex">Codex</option>
              <option value="axonhub">AxonHub</option>
              <option value="codexmanager">Codex-Manager</option>
            </select>
            <div class="tool-stat-label">输出格式</div>
          </div>
          <div class="tool-stat">
            <div id="sessionStatCount" class="tool-stat-value">0</div>
            <div class="tool-stat-label">账号数</div>
          </div>
          <div class="tool-stat">
            <div id="sessionStatErrors" class="tool-stat-value">0</div>
            <div class="tool-stat-label">跳过项</div>
          </div>
        </div>
        <div class="session-account-table mt-3 overflow-hidden rounded border bg-white">
          <div class="max-h-56 overflow-auto">
            <table class="w-full table-fixed border-collapse text-sm">
              <thead class="sticky top-0 bg-slate-100 text-xs font-semibold text-slate-600">
                <tr>
                  <th class="w-[30%] border-b px-3 py-2 text-left">名称</th>
                  <th class="w-[42%] border-b px-3 py-2 text-left">邮箱</th>
                  <th class="w-[28%] border-b px-3 py-2 text-left">过期时间</th>
                </tr>
              </thead>
              <tbody id="sessionAccountRows">
                <tr>
                  <td colspan="3" class="px-3 py-4 text-sm text-slate-500">暂无可转换账号。</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        <div id="sessionIssues" class="tool-issues"></div>
        <pre class="session-converter-textarea tool-code-output mt-3"><code id="sessionOutput" class="language-json"></code></pre>
        <p id="sessionOutputStatus" class="tool-status-line"></p>
      </div>
    </section>
  </section>

  <script is:inline slot="scripts" defer src={highlightScriptUrl}></script>
  <script is:inline slot="scripts" defer src={sessionConverterScriptUrl}></script>
</PublicPage>
