---
/*
文件说明: 渲染单个官方订阅套餐的独立 SSR 比价 URL。
*/
import OfficialPriceContent from '../../components/OfficialPriceContent.astro';
import { localizeOfficialPriceGroups } from '../../localized-display.js';
import PublicPage from '../../layouts/PublicPage.astro';
import { buildOfficialPriceGroupsForActiveSlug, resolveOfficialPriceSlug } from '../../official-price.js';
import { buildSeoContext } from '../../seo.js';
import { publicSiteUrl } from '../../site.js';
import { formatBeijingRefreshTime, loadOfficialPriceCatalog, loadOfficialPricesByUrlSlug } from '../../store.js';

const requestedSlug = Astro.params.slug || '';
const [catalog, activePrices] = await Promise.all([
  loadOfficialPriceCatalog(),
  loadOfficialPricesByUrlSlug(requestedSlug),
]);
const groups = localizeOfficialPriceGroups(
  buildOfficialPriceGroupsForActiveSlug(catalog, activePrices, requestedSlug),
  Astro.locals.locale,
);
const currentGroup = resolveOfficialPriceSlug(requestedSlug, groups);

if (!currentGroup) return Astro.redirect(Astro.locals.localizePath('/official-price'), 302);
if (Astro.params.slug !== currentGroup.urlSlug) return Astro.redirect(Astro.locals.localizePath(currentGroup.pathname), 301);

const latestFetchedAt = activePrices.reduce<string | null>((latest, price) => {
  if (!price.fetchedAt) return latest;
  if (!latest) return price.fetchedAt;
  return new Date(price.fetchedAt).getTime() > new Date(latest).getTime() ? price.fetchedAt : latest;
}, null);
const updateTime = latestFetchedAt ? formatBeijingRefreshTime(latestFetchedAt) : Astro.locals.messages.labels.notRecorded;

const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: currentGroup.pathname,
  title: `${currentGroup.displayName} ${Astro.locals.messages.officialPrice.titleSuffix}`,
  description: Astro.locals.messages.officialPrice.dynamicDescription.replace('{displayName}', currentGroup.displayName),
  imagePath: '/og-cardnav.png',
  type: 'webpage',
  breadcrumbs: [
    { name: Astro.locals.messages.nav.officialPrice, pathname: '/official-price' },
    { name: currentGroup.displayName, pathname: currentGroup.pathname },
  ],
  locale: Astro.locals.locale,
});
---

<PublicPage activeNav="official-price" {...seo}>
  <OfficialPriceContent groups={groups} currentGroup={currentGroup} updateTime={updateTime} />
</PublicPage>
