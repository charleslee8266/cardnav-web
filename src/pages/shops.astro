---
/*
文件说明: 渲染 CardNav 卡网商家页，提供第三方商家和商品的搜索、筛选与排序能力。
*/
import PageHero from '../components/PageHero.astro';
import PublicPage from '../layouts/PublicPage.astro';
import { officialPricePathname } from '../official-price.js';
import { buildSeoContext } from '../seo.js';
import { quickPlanGatewayFamilyName, quickPlanGatewayPath, quickPlanSearchSeoPath, quickPlanSearchTerms, type QuickPlanSearchTerm } from '../shop-plan-search.js';
import { buildShopSearchPageMeta } from '../shop-search-page-meta.js';
import pageWidgetsScriptUrl from '../scripts/page-widgets.js?url';
import { publicSiteUrl, telegramGroupUrl } from '../site.js';
import shopsMerchantViewScriptUrl from '../scripts/shops-merchant-view.js?url';
import shopsScriptUrl from '../scripts/index.js?url';
import { loadOfficialPriceCatalog, loadShopProductsData, loadPopularSearchTerms } from '../store.js';

type Props = {
  seoSearchTerm?: QuickPlanSearchTerm | null;
};

const initialProductLimitValue = 40;
const t = Astro.locals.messages;
const linkTo = Astro.locals.localizePath;
const requestUrl = new URL(Astro.request.url);
const seoSearchTerm = Astro.props.seoSearchTerm ?? null;
const initialSearchQuery = seoSearchTerm?.query ?? requestUrl.searchParams.get('q')?.trim() ?? '';
const initialSort = seoSearchTerm ? 'price-asc' : requestUrl.searchParams.get('sort')?.trim() ?? '';
const seoSearchPageMeta = seoSearchTerm
  ? buildShopSearchPageMeta(seoSearchTerm.label, {
      searchResultsTitle: t.shops.searchResultsTitle,
      searchResultsDescription: t.shops.searchResultsDescription,
    })
  : null;
const pageTitle = seoSearchPageMeta?.pageTitle ?? t.shops.seoTitle;
const pageDescription = seoSearchPageMeta?.pageDescription ?? t.shops.seoDescription;
const heroTitle = seoSearchPageMeta?.heroTitle ?? t.shops.title;
const heroDescription = seoSearchPageMeta?.heroDescription ?? t.shops.description;
const seoPathname = seoSearchTerm ? quickPlanSearchSeoPath(seoSearchTerm) : '/shops';
const hasNonCanonicalQuery = !seoSearchTerm && requestUrl.search.length > 0;
const [data, popularSearchResult, officialPriceCatalog] = await Promise.all([
  loadShopProductsData({ productLimit: initialProductLimitValue }),
  loadPopularSearchTerms(10, [...t.home.presetPopularSearchTerms]),
  loadOfficialPriceCatalog(),
]);
const popularSearchTerms = popularSearchResult.terms;
const officialPriceUrlSlugs = new Set(officialPriceCatalog.map(entry => entry.urlSlug.trim()).filter(Boolean));
const initialOfficialPricePath = seoSearchTerm?.officialPriceSlug && officialPriceUrlSlugs.has(seoSearchTerm.officialPriceSlug)
  ? linkTo(officialPricePathname(seoSearchTerm.officialPriceSlug))
  : '';
const initialOfficialPriceTipLabel = initialOfficialPricePath
  ? t.shops.officialPriceTip.replace('{term}', seoSearchTerm?.label ?? '')
  : '';
const initialGatewayPath = seoSearchTerm ? quickPlanGatewayPath(seoSearchTerm) : '';
const initialGatewayTipPath = initialGatewayPath ? linkTo(initialGatewayPath) : '';
const initialGatewayTipLabel = initialGatewayTipPath
  ? t.shops.gatewayTip.replace('{term}', seoSearchTerm ? quickPlanGatewayFamilyName(seoSearchTerm) : '')
  : '';
const renderedProducts = data.products.map(product => ({
  categoryName: product.categoryName,
  name: product.name,
  priceNumber: typeof product.priceNumber === 'number' ? product.priceNumber : null,
  priceUnit: typeof product.priceUnit === 'string' ? product.priceUnit : null,
  productUrl: product.productUrl,
  stock: product.stock,
  inStock: product.inStock,
  refreshedAt: product.refreshedAt || null,
  refreshTime: product.refreshTime || '',
  clickCount: product.clickCount || 0,
  siteId: product.siteId || '',
  siteName: product.siteName || '',
  siteUrl: product.siteUrl || '',
  siteProductRefreshSuccessAt: product.siteProductRefreshSuccessAt || null,
  siteProductRefreshSuccessTime: product.siteProductRefreshSuccessTime || '',
  score: product.score || 0,
}));
const shopBreadcrumbs = seoSearchTerm
  ? [
      { name: t.shops.title, pathname: '/shops' },
      { name: seoSearchTerm.label, pathname: seoPathname },
    ]
  : [{ name: t.shops.title, pathname: '/shops' }];
const shopListItems = renderedProducts.slice(0, 20).map((product, index) => ({
  name: `${product.categoryName} - ${product.name}`,
  url: product.productUrl,
  position: index + 1,
}));
const shopProductSchemaItems = renderedProducts.slice(0, 20).map(product => ({
  name: `${product.categoryName} - ${product.name}`,
  url: product.productUrl,
  price: typeof product.priceNumber === 'number' && Number.isFinite(product.priceNumber) ? product.priceNumber : undefined,
  priceCurrency: product.priceUnit === '$' ? 'USD' : 'CNY',
  availability: product.inStock ? 'InStock' as const : 'OutOfStock' as const,
}));
const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: seoPathname,
  title: pageTitle,
  description: pageDescription,
  imagePath: '/og-cardnav.png',
  type: 'webpage',
  noindex: hasNonCanonicalQuery,
  breadcrumbs: shopBreadcrumbs,
  listItems: shopListItems,
  products: shopProductSchemaItems,
  locale: Astro.locals.locale,
});
const normalSeo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/shops',
  title: t.shops.seoTitle,
  description: t.shops.seoDescription,
  imagePath: '/og-cardnav.png',
  type: 'website',
  locale: Astro.locals.locale,
});

const renderedSites = data.sites.map(site => ({
  id: site.id || '',
  name: site.name,
  url: site.url || '',
  lastProductRefreshSuccessAt: site.lastProductRefreshSuccessAt || null,
  lastProductRefreshSuccessTime: site.lastProductRefreshSuccessTime || '',
  score: site.score || 0,
}));
const popularSearchTermsValue = popularSearchTerms.map(term => term.trim()).filter(Boolean);
const shopsScriptMessages = {
  loading: t.shops.script.loading,
  displaySummary: t.shops.script.displaySummary,
  stockPrefix: t.shops.script.stockPrefix,
  latestRefreshPrefix: t.shops.script.latestRefreshPrefix,
  noData: t.shops.script.noData,
  officialPriceTip: t.shops.officialPriceTip,
  gatewayTip: t.shops.gatewayTip,
  searchResultsTitle: t.shops.searchResultsTitle,
  searchResultsDescription: t.shops.searchResultsDescription,
  titleSuffix: t.seo.titleSuffix,
  ascending: t.shops.script.ascending,
  descending: t.shops.script.descending,
  currentSort: t.shops.script.currentSort,
  clickSort: t.shops.script.clickSort,
  merchantViewScriptUrl: shopsMerchantViewScriptUrl,
  productFavorite: t.shops.productFavorite,
  merchantFavorite: t.shops.merchantFavorite,
  cancelProductFavorite: t.shops.cancelProductFavorite,
  cancelMerchantFavorite: t.shops.cancelMerchantFavorite,
  inStock: t.labels.inStock,
  soldOut: t.labels.soldOut,
  defaultPageTitle: normalSeo.pageTitle,
  defaultHeroTitle: t.shops.title,
  defaultHeroDescription: t.shops.description,
  seoSearchQuery: seoSearchTerm?.query ?? '',
  seoSearchPath: seoSearchTerm ? linkTo(quickPlanSearchSeoPath(seoSearchTerm)) : '',
  searchPlaceholder: t.shops.searchPlaceholder,
  tableLabels: {
    sequence: t.labels.sequence,
    product: t.labels.product,
    price: t.labels.price,
    stock: t.labels.stock,
    category: t.labels.category,
    merchant: t.labels.merchant,
    latestRefresh: t.labels.latestRefresh,
  },
};
const flatSortColumns = [
  { key: 'productName', type: 'text', label: t.labels.product },
  { key: 'priceValue', type: 'number', label: t.labels.price },
  { key: 'stockValue', type: 'number', label: t.labels.stock },
  { key: 'categoryName', type: 'text', label: t.labels.category },
  { key: 'siteName', type: 'text', label: t.labels.merchant },
  { key: 'productRefreshedAt', type: 'number', label: t.labels.latestRefresh },
];
const shopProductsJsonValue = JSON.stringify({
  sites: renderedSites,
  products: renderedProducts,
  totalSiteCount: data.totalSiteCount,
  totalProductCount: data.totalProductCount,
  latestRefreshTime: data.latestRefreshTime,
  initialProductLimit: initialProductLimitValue,
  isPartial: data.isPartial,
}).replace(/[<>&\u2028\u2029]/g, character => ({
  '<': '\\u003c',
  '>': '\\u003e',
  '&': '\\u0026',
  '\u2028': '\\u2028',
  '\u2029': '\\u2029',
})[character] || character);
---

<PublicPage activeNav="shops" {...seo}>
  <PageHero
    title={heroTitle}
    description={heroDescription}
    titleId="shopPageHeroTitle"
    descriptionId="shopPageHeroDescription"
  >
    <p slot="note" class="page-hero-note">{t.shops.note}</p>
    <button
      slot="aside"
      id="openShopSubmitModal"
      type="button"
      class="btn btn-primary btn-md shrink-0"
      data-umami-event="shop-submit-open-click"
      data-umami-event-name={t.shops.submitMerchant}
    >
      {t.shops.submitMerchant}
    </button>
  </PageHero>

  <section>
    <a href={linkTo('/guide/choose-reliable-merchant')} data-umami-event="guide-url-click" data-umami-event-source-page={linkTo('/shops')} data-umami-event-target-page={linkTo('/guide/choose-reliable-merchant')} data-umami-event-url={linkTo('/guide/choose-reliable-merchant')} class="alert alert-info alert-soft shadow-sm flex items-start justify-between text-left hover:bg-info/10 transition-colors text-base-content">
      <div>
        <span class="font-bold text-base block text-base-content">{t.shops.guideTitle}</span>
        <span class="text-sm text-base-content/85 block mt-1">{t.shops.guideDescription}</span>
      </div>
      <div class="btn btn-sm btn-ghost text-primary hover:bg-transparent shrink-0">{t.actions.read} ➜</div>
    </a>
  </section>

  <section class="card bg-base-100 border border-base-300 shadow-sm">
    <form id="filters" class="card-body p-5 flex flex-col gap-3" method="get">
      <div class="collection-summary flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-base-content/70">
        <span>{t.labels.collectedSites}：<span class="font-bold text-primary">{data.totalSiteCount}</span></span>
        <span>{t.labels.products}：<span class="font-bold text-primary">{data.totalProductCount}</span></span>
        <span>{t.labels.currentProducts}：<span id="currentProductCount" class="font-bold text-primary">{data.totalProductCount}</span></span>
        {data.latestRefreshTime && <span>{t.labels.latestRefresh}：{data.latestRefreshTime}</span>}
      </div>
      <div class="relative w-full max-w-3xl">
        <input id="searchFilter" name="q" value={initialSearchQuery} class="input input-bordered w-full pr-11" placeholder={t.shops.searchPlaceholder} autocomplete="off" />
        <button id="advancedSearchHelp" type="button" class="absolute right-3 top-1/2 flex h-5 w-5 -translate-y-1/2 items-center justify-center rounded-full border border-base-content/30 bg-base-100 text-xs font-bold leading-none text-base-content/60 hover:border-primary hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary" aria-label={t.shops.advancedSearchLabel} data-inline-help data-tip={t.shops.advancedSearchTip}>i</button>
      </div>
      <div class="flex flex-wrap items-center gap-x-2.5 gap-y-1.5">
        <label class="label cursor-pointer flex items-center gap-1 text-sm p-0">
          <input id="showSoldOutFilter" name="showSoldOut" value="1" type="checkbox" class="checkbox checkbox-primary checkbox-xs cursor-pointer" />
          <span>{t.shops.showSoldOut}</span>
        </label>
        <label class="label cursor-pointer flex items-center gap-1 text-sm p-0">
          <input id="matchCategoryFilter" name="matchCategory" value="1" type="checkbox" class="checkbox checkbox-primary checkbox-xs cursor-pointer" />
          <span>{t.shops.matchCategory}</span>
        </label>
        <label class="label cursor-pointer flex items-center gap-1 text-sm p-0">
          <input id="matchMerchantFilter" name="matchMerchant" value="1" type="checkbox" class="checkbox checkbox-primary checkbox-xs cursor-pointer" />
          <span>{t.shops.matchMerchant}</span>
        </label>
        <label class="label cursor-pointer flex items-center gap-1 text-sm p-0">
          <input id="groupByMerchantFilter" name="groupByMerchant" value="1" type="checkbox" class="checkbox checkbox-primary checkbox-xs cursor-pointer" />
          <span>{t.shops.groupByMerchant}</span>
        </label>
        <div class="flex flex-wrap items-center gap-x-1 gap-y-1">
          <span class="text-sm text-base-content/80">{t.labels.price}</span>
          <button id="priceFilterHelp" type="button" class="flex h-4 w-4 items-center justify-center rounded-full border border-base-content/30 bg-base-100 text-[10px] font-bold leading-none text-base-content/60 hover:border-primary hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary" aria-label={t.shops.priceFilterHint} data-inline-help data-tip={t.shops.priceFilterHint}>i</button>
          <input id="priceMin" name="priceMin" type="number" min="0" step="0.01" inputmode="decimal" class="input input-bordered input-sm w-24" placeholder={t.shops.minPrice} autocomplete="off" />
          <span class="text-xs text-base-content/40">~</span>
          <input id="priceMax" name="priceMax" type="number" min="0" step="0.01" inputmode="decimal" class="input input-bordered input-sm w-24" placeholder={t.shops.maxPrice} autocomplete="off" />
        </div>
        <div class="flex items-center gap-1">
          <span class="text-sm text-base-content/80">{t.shops.sort}</span>
          <select id="flatSortSelect" name="sort" class="select select-bordered select-sm w-32" autocomplete="off">
            <option value="default" selected={!initialSort || initialSort === 'default'}>{t.shops.defaultSort}</option>
            <option value="price-asc" selected={initialSort === 'price-asc'}>{t.shops.priceAsc}</option>
            <option value="stock-desc" selected={initialSort === 'stock-desc'}>{t.shops.stockDesc}</option>
            <option value="refresh-desc" selected={initialSort === 'refresh-desc'}>{t.shops.refreshDesc}</option>
            <option value="custom" hidden>{t.shops.headerSort}</option>
          </select>
        </div>
      </div>
      <div id="quickPlanRow" class="flex flex-wrap items-center gap-1" aria-label={t.shops.quickPlanSearch}>
        <span class="text-sm font-normal text-base-content/65 uppercase tracking-wider">{t.shops.quickPlanSearch}</span>
        {quickPlanSearchTerms.map(term => (
          <button
            type="button"
            class="btn btn-outline btn-xs min-h-0 h-6 rounded-full border-base-300 px-1.5 text-sm! font-normal text-base-content/85 hover:text-base-content! hover:border-base-content/30! hover:bg-base-200!"
            data-quick-plan-query={term.query}
            data-quick-plan-path={linkTo(quickPlanSearchSeoPath(term))}
            data-official-price-path={term.officialPriceSlug && officialPriceUrlSlugs.has(term.officialPriceSlug) ? linkTo(officialPricePathname(term.officialPriceSlug)) : undefined}
            data-gateway-path={quickPlanGatewayPath(term) ? linkTo(quickPlanGatewayPath(term)) : undefined}
            data-gateway-model-family={term.gatewayModelFamily}
            data-gateway-model-family-name={term.gatewayModelFamilyName}
          >
            {term.label}
          </button>
        ))}
      </div>
      <div class="flex flex-wrap items-center gap-1">
        <span class="text-sm font-normal text-base-content/65 uppercase tracking-wider">{t.labels.popularSearch}</span>
        <div id="quickTagFilters" class="flex flex-wrap gap-0.5" aria-label={t.shops.hotSearchTags}>
          {popularSearchTermsValue.map(term => {
            const tagKey = term.trim().toLowerCase().replace(/\s+/g, '-');
            return (
              <button type="button" class="btn btn-outline btn-xs min-h-0 h-6 rounded-full border-base-300 px-1.5 text-sm! font-normal text-base-content/85 hover:text-base-content! hover:border-base-content/30! hover:bg-base-200!" data-tag-key={tagKey} data-umami-event="quick-search-click" data-umami-event-name={term}>{term}</button>
            );
          })}
        </div>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <a
          id="officialPriceTip"
          href={initialOfficialPricePath || '#'}
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            initialOfficialPricePath ? 'inline-flex' : 'hidden',
            'w-fit items-center gap-1 rounded-md bg-info/10 px-2 py-1 text-xs leading-5 text-info-content hover:bg-info/15 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary',
          ]}
          data-umami-event="quick-plan-official-price-tip-click"
          data-umami-event-url={initialOfficialPricePath || undefined}
          data-umami-event-name={initialOfficialPricePath ? seoSearchTerm?.label : undefined}
        >
          <span data-official-price-tip-label>{initialOfficialPriceTipLabel}</span>
          <svg aria-hidden="true" class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m13 6 6 6-6 6"></path>
          </svg>
        </a>
        <a
          id="gatewayTip"
          href={initialGatewayTipPath || '#'}
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            initialGatewayTipPath ? 'inline-flex' : 'hidden',
            'w-fit items-center gap-1 rounded-md bg-info/10 px-2 py-1 text-xs leading-5 text-info-content hover:bg-info/15 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary',
          ]}
          data-umami-event="quick-plan-gateway-tip-click"
          data-umami-event-url={initialGatewayTipPath || undefined}
          data-umami-event-name={initialGatewayTipPath && seoSearchTerm ? quickPlanGatewayFamilyName(seoSearchTerm) : undefined}
        >
          <span data-gateway-tip-label>{initialGatewayTipLabel}</span>
          <svg aria-hidden="true" class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m13 6 6 6-6 6"></path>
          </svg>
        </a>
      </div>
    </form>
  </section>

  <section id="emptyState" class="shops-empty-state hidden" aria-live="polite">
    <p>{t.shops.emptyState}</p>
  </section>

  <section id="flatProductView" class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden">
    <div class="bg-base-200/50 px-4 py-2 text-xs font-semibold text-base-content/60 border-b border-base-300">{t.shops.tableHint}</div>
    <div class="product-table-scroll">
      <table class="table table-zebra w-full flat-product-table border-collapse">
        <thead class="bg-base-200 text-base-content text-base">
          <tr>
            <th scope="col" class="table-head-index w-14 text-center">{t.labels.sequence}</th>
            {flatSortColumns.map(column => (
              <th scope="col" class="flat-sort-head" aria-sort="none">
                <button type="button" class="flat-sort-button" data-sort-key={column.key} data-sort-type={column.type} title={`${column.label}${t.shops.sortTitleSuffix}`}>
                  <span class="flat-sort-label">{column.label}</span>
                  <span class="sort-indicator" aria-hidden="true">
                    <svg class="sort-icon sort-icon-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m7 15 5 5 5-5"></path>
                      <path d="m7 9 5-5 5 5"></path>
                    </svg>
                    <svg class="sort-icon sort-icon-asc" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m5 12 7-7 7 7"></path>
                      <path d="M12 19V5"></path>
                    </svg>
                    <svg class="sort-icon sort-icon-desc" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 5v14"></path>
                      <path d="m19 12-7 7-7-7"></path>
                    </svg>
                  </span>
                  <span class="sort-status sr-only">{t.shops.clickSort}</span>
                </button>
              </th>
            ))}
          </tr>
        </thead>

        <tbody id="flatProductRows"></tbody>
      </table>
    </div>
  </section>

  <section id="flatProductProgressiveLoad" class="progressive-load-panel flex flex-col items-center gap-3">
    <p id="flatProductLoadSummary" class="progressive-load-summary text-xs text-base-content/50 hidden"></p>
    <button id="flatProductLoadMoreButton" type="button" class="btn btn-outline btn-sm hidden">{t.shops.loadMoreProducts}</button>
  </section>

  <section id="merchantGroupedView" class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden" hidden>
    <div class="merchant-table-head bg-base-200 font-bold text-sm text-base-content">
      <div class="merchant-head-index text-center w-14">{t.labels.sequence}</div>
      <div class="merchant-head-cell">{t.labels.merchant}</div>
      <div class="merchant-head-cell">{t.labels.product}</div>
    </div>
    <div id="merchantRows"></div>
  </section>

  <dialog id="shopSubmitDialog" class="modal">
    <div class="modal-box max-w-2xl p-0">
      <section class="card bg-base-100 shadow-none">
        <div class="card-body p-5">
          <div class="flex items-start justify-between gap-4">
            <PageHero
              title={t.shops.submitMerchant}
              description={t.shops.submitDescription}
              heading="h2"
              compact
              wrapCard={false}
            />
            <form method="dialog">
              <button type="submit" class="btn btn-ghost btn-circle btn-sm" aria-label={t.shops.closeSubmitDialog}>✕</button>
            </form>
          </div>

          <div class="alert alert-info alert-soft shadow-sm mt-4 flex flex-col items-start gap-1.5 text-left text-base-content">
            <span class="font-bold text-sm">{t.shops.cooperationTitle}</span>
            <p class="text-sm text-base-content/85 leading-6">{t.shops.cooperationDescription}</p>
            <a href={telegramGroupUrl} target="_blank" rel="noopener noreferrer" data-umami-event="shop-submit-telegram-click" data-umami-event-url={telegramGroupUrl} data-umami-event-name={t.actions.contactTelegram} class="btn btn-primary btn-sm mt-2 inline-flex items-center gap-2">
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="h-4 w-4 shrink-0" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m22 2-7 20-4-9-9-4Z"></path>
                <path d="M22 2 11 13"></path>
              </svg>
              {t.actions.contactTelegram}
            </a>
          </div>

          <form id="submitForm" class="form-control gap-3 mt-4" method="post" action="/api/submit">
            <div>
              <label for="urlInput" class="label font-semibold text-sm pb-1">URL</label>
              <input id="urlInput" name="url" type="url" required value="" class="input input-bordered w-full" placeholder="https://example.com" autocomplete="url" />
            </div>
            <p id="clientError" class="hidden text-sm text-error font-medium">{t.submit.invalidUrl}</p>
            <p id="submitError" class="hidden text-sm text-error font-medium"></p>
            <p id="submitSuccess" class="hidden text-sm text-success font-medium"></p>
            <div class="card-actions justify-start mt-2">
              <button type="submit" data-umami-event="submit-click" data-umami-event-url="" class="btn btn-primary">
                {t.actions.submit}
              </button>
            </div>
          </form>
        </div>
      </section>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button type="submit" aria-label={t.shops.closeSubmitBackdrop}>close</button>
    </form>
  </dialog>

  <script is:inline type="application/json" id="shop-products-data" set:html={shopProductsJsonValue}></script>
  <script is:inline type="application/json" id="shops-messages" set:html={JSON.stringify(shopsScriptMessages)}></script>
  <script is:inline slot="scripts" type="module" src={shopsScriptUrl}></script>
  <script is:inline slot="scripts" defer src={pageWidgetsScriptUrl}></script>
</PublicPage>
