---
/*
文件说明: 渲染 AI 大模型 API 中转站入口页，通过中转站和模型两个标签页展示前二十名并支持本地加载更多。
*/
import PublicPage from '../layouts/PublicPage.astro';
import SortableTableHeader from '../components/SortableTableHeader.astro';
import { buildSeoContext } from '../seo.js';
import { publicSiteUrl, telegramGroupUrl } from '../site.js';
import { loadGatewayModels, loadGatewaySites } from '../store.js';
import gatewayHomeScriptUrl from '../scripts/llm-gateway-home.js?url';
import sortableTablesScriptUrl from '../scripts/sortable-tables.js?url';

const t = Astro.locals.messages;
const linkTo = Astro.locals.localizePath;
const [gatewayData, gatewayModelData] = await Promise.all([loadGatewaySites(), loadGatewayModels()]);
const topSites = gatewayData.sites.slice(0, 20);
const topModels = gatewayModelData.models.slice(0, 20);
const deferredSites = gatewayData.sites.slice(20);
const deferredModels = gatewayModelData.models.slice(20);
const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/llm-gateway',
  title: t.llmGateway.seoTitle,
  description: t.llmGateway.seoDescription,
  imagePath: '/og-cardnav.png',
  type: 'website',
  locale: Astro.locals.locale,
});

function uniqueLabels(items: string[], limit?: number) {
  const seen = new Set<string>();
  const labels: string[] = [];
  for (const item of items) {
    const label = item.trim();
    const key = label.toLowerCase();
    if (!label || seen.has(key)) continue;
    seen.add(key);
    labels.push(label);
    if (limit && labels.length >= limit) break;
  }
  return labels;
}

function collectFilterOptions(items: string[][]) {
  return uniqueLabels(items.flat()).sort((a, b) => a.localeCompare(b));
}

const paymentMethodLabels = t.llmGateway.paymentMethodLabels;

function paymentLabel(key: string): string {
  return paymentMethodLabels[key] || key;
}

function paymentIcon(key: string): { src: string | null; fallback: string } {
  const icons: Record<string, { src: string; fallback: string }> = {
    alipay: { src: '/assets/payment-icons/alipay.svg', fallback: 'A' },
    wechat: { src: '/assets/payment-icons/wechat.svg', fallback: 'W' },
    visa: { src: '/assets/payment-icons/visa.svg', fallback: 'V' },
    mastercard: { src: '/assets/payment-icons/mastercard.svg', fallback: 'M' },
    stripe: { src: '/assets/payment-icons/stripe.svg', fallback: 'S' },
    paypal: { src: '/assets/payment-icons/paypal.svg', fallback: 'P' },
    tether: { src: '/assets/payment-icons/tether.svg', fallback: 'T' },
    bitcoin: { src: '/assets/payment-icons/bitcoin.svg', fallback: 'B' },
    applepay: { src: '/assets/payment-icons/applepay.svg', fallback: 'A' },
    googlepay: { src: '/assets/payment-icons/googlepay.svg', fallback: 'G' },
  };
  return icons[key] || { src: null, fallback: key.trim().slice(0, 1).toUpperCase() };
}

function formatPositiveScore(value: number | null) {
  return value === null || !Number.isFinite(value) || value <= 0 ? '-' : value.toFixed(2);
}

function modelHref(modelId: string) {
  return linkTo(`/llm-gateway/models/${encodeURIComponent(modelId)}`);
}

function gatewaySiteClickAttrs(site: { name: string; slug: string; outboundUrl: string }) {
  const targetPage = linkTo(`/llm-gateway/${site.slug}`);
  return {
    'data-umami-event': 'gateway-site-click',
    'data-umami-event-name': site.name,
    'data-umami-event-target-page': targetPage,
    'data-umami-event-url': targetPage,
  };
}

function gatewaySiteOpenAttrs(site: { name: string; outboundUrl: string }) {
  return {
    'data-umami-event': 'gateway-site-open-click',
    'data-umami-event-name': site.name,
    'data-umami-event-url': site.outboundUrl,
  };
}

function gatewayModelClickAttrs(model: { modelId: string; modelFamily: string }) {
  const targetPage = modelHref(model.modelId);
  return {
    'data-umami-event': 'gateway-model-click',
    'data-umami-event-name': model.modelId,
    'data-umami-event-family': model.modelFamily,
    'data-umami-event-target-page': targetPage,
    'data-umami-event-url': targetPage,
  };
}

const modelFilterOptions = collectFilterOptions(gatewayData.sites.map(site => site.displayModelFamilies));
const paymentFilterOptions = collectFilterOptions(gatewayData.sites.map(site => site.paymentMethods));
const hasMoreSites = deferredSites.length > 0;
const hasMoreModels = deferredModels.length > 0;
const gatewayHomeConfig = {
  gatewayLinkPrefix: linkTo('/llm-gateway'),
  modelLinkPrefix: linkTo('/llm-gateway/models'),
  sitesApi: `/api/llm-gateway/sites.json?offset=20&locale=${encodeURIComponent(Astro.locals.locale)}`,
  modelsApi: `/api/llm-gateway/models.json?offset=20&locale=${encodeURIComponent(Astro.locals.locale)}`,
  detailLabel: t.llmGateway.viewDetail,
  openLabel: t.actions.open,
  rankLabel: t.llmGateway.rank,
  basicInfoLabel: t.llmGateway.basicInfo,
  scoreLabel: t.labels.score,
  supportedModelsLabel: t.llmGateway.supportedModels,
  modelCountLabel: t.llmGateway.modelCount,
  paymentMethodsLabel: t.llmGateway.paymentMethods,
  paymentMethodLabels: t.llmGateway.paymentMethodLabels,
  modelLabel: t.labels.model,
  modelFamilyLabel: t.llmGateway.modelFamily,
  supportedGatewayCountLabel: t.llmGateway.supportedGatewayCount,
};
---

<PublicPage activeNav="llm-gateway" {...seo}>
  <section class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body p-5">
      <div class="page-hero-shell">
        <div class="page-hero-main">
          <div class="page-hero-wrap">
            <h1 class="page-hero-title">{t.llmGateway.title}</h1>
            <p class="page-hero-copy">{t.llmGateway.description}</p>
            <p class="page-hero-note">
              {t.llmGateway.notePrefix}
              <a href={telegramGroupUrl} target="_blank" rel="noopener noreferrer" class="link link-primary font-medium" data-umami-event="gateway-report-click" data-umami-event-url={telegramGroupUrl} data-umami-event-name={t.llmGateway.reportIssue}>{t.llmGateway.reportIssue}</a>
              {t.llmGateway.noteSuffix}
            </p>
          </div>
        </div>
        <div class="stats stats-vertical sm:stats-horizontal border border-base-300 bg-base-100 shadow-none">
          <div class="stat px-4 py-3">
            <div class="stat-title text-xs">{t.llmGateway.listedSites}</div>
            <div class="stat-value text-2xl text-primary">{gatewayData.totalSiteCount}</div>
          </div>
          <div class="stat px-4 py-3">
            <div class="stat-title text-xs">{t.llmGateway.sitesWithPrices}</div>
            <div class="stat-value text-2xl text-secondary">{gatewayData.sitesWithPricesCount}</div>
          </div>
          <div class="stat px-4 py-3">
            <div class="stat-title text-xs">{t.llmGateway.modelRecords}</div>
            <div class="stat-value text-2xl">{gatewayModelData.totalModelCount}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {gatewayData.sites.length === 0 ? (
    <section class="alert alert-warning shadow-sm max-w-md mx-auto my-6 justify-center">
      <span>{t.llmGateway.empty}</span>
    </section>
  ) : (
    <section class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden" data-gateway-home>
      <div class="border-b border-base-300 bg-base-100 px-4 py-3">
        <div class="tool-tablist-wrap">
          <div class="tool-tablist" role="tablist" aria-label={t.llmGateway.title}>
            <button type="button" class="tool-tab tool-tab-active" role="tab" aria-selected="true" aria-controls="gatewaySitesPanel" id="gatewaySitesTab" data-gateway-tab="sites">
              {t.llmGateway.gatewayListTitle}
              <span class="tool-tab-badge">{gatewayData.totalSiteCount}</span>
            </button>
            <button type="button" class="tool-tab tool-tab-inactive" role="tab" aria-selected="false" aria-controls="gatewayModelsPanel" id="gatewayModelsTab" data-gateway-tab="models">
              {t.llmGateway.modelListTitle}
              <span class="tool-tab-badge">{gatewayModelData.totalModelCount}</span>
            </button>
          </div>
        </div>
      </div>

      <div id="gatewaySitesPanel" role="tabpanel" aria-labelledby="gatewaySitesTab" data-gateway-panel="sites">
        <div class="card-body p-0">
          <div class="gateway-filter-grid grid gap-3 border-b border-base-300 p-4 md:grid-cols-[minmax(0,1fr)_180px_180px]">
            <label class="input input-bordered flex h-11 items-center gap-2">
              <input data-home-site-search type="search" class="grow text-sm" placeholder={t.llmGateway.searchPlaceholder} />
            </label>
            <select data-home-site-family class="select select-bordered h-11 min-h-11 text-sm" aria-label={t.llmGateway.familyFilter}>
              <option value="">{t.llmGateway.allFamilies}</option>
              {modelFilterOptions.map(model => <option value={model.toLowerCase()}>{model}</option>)}
            </select>
            <select data-home-site-payment class="select select-bordered h-11 min-h-11 text-sm" aria-label={t.llmGateway.paymentFilter}>
              <option value="">{t.llmGateway.allPaymentMethods}</option>
              {paymentFilterOptions.map(method => <option value={method}>{paymentLabel(method)}</option>)}
            </select>
          </div>
          <div class="gateway-table-scroll">
            <table class="table table-zebra gateway-home-table gateway-site-table w-full table-fixed align-top border-collapse" data-sortable-table>
              <thead class="bg-base-200 text-sm font-semibold text-base-content">
                <tr>
                  <SortableTableHeader label={t.llmGateway.rank} sortKey="rank" sortType="number" class="w-14" />
                  <SortableTableHeader label={t.llmGateway.basicInfo} sortKey="name" class="w-[34%]" />
                  <SortableTableHeader label={t.labels.score} sortKey="score" sortType="number" class="w-20" />
                  <SortableTableHeader label={t.llmGateway.supportedModels} sortKey="families" class="w-[24%]" />
                  <SortableTableHeader label={t.llmGateway.modelCount} sortKey="modelCount" sortType="number" class="w-20" />
                  <SortableTableHeader label={t.llmGateway.paymentMethods} sortKey="payments" class="w-28" />
                </tr>
              </thead>
              <tbody data-gateway-home-sites-list>
            {topSites.map((site, index) => {
              const families = uniqueLabels(site.displayModelFamilies, 8);
              const paymentMethods = uniqueLabels(site.paymentMethods, 6);
              return (
                <tr data-home-site-card data-search={`${site.name} ${site.url} ${site.host} ${site.displayModelFamilies.join(' ')} ${site.paymentMethods.map(paymentLabel).join(' ')}`.toLowerCase()} data-families={families.map(item => item.toLowerCase()).join(',')} data-payments={paymentMethods.join(',')} data-original-order={String(index)} data-sort-rank={String(index + 1)} data-sort-name={site.name} data-sort-score={String(site.siteScore || 0)} data-sort-families={families.join(' ')} data-sort-model-count={String(site.modelCount || 0)} data-sort-payments={paymentMethods.map(paymentLabel).join(' ')}>
                  <td data-label={t.llmGateway.rank} class="font-mono text-sm text-primary">#{index + 1}</td>
                  <td data-label={t.llmGateway.basicInfo}>
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-stretch sm:justify-between">
                      <div class="min-w-0 space-y-2">
                        <div class="flex flex-wrap items-center gap-2">
                          <a href={linkTo(`/llm-gateway/${site.slug}`)} class="link link-hover break-words text-base font-semibold text-base-content" {...gatewaySiteClickAttrs(site)}>{site.name}</a>
                          {site.displayFamily ? <span class="badge badge-ghost font-medium">{site.displayFamily}</span> : null}
                        </div>
                        {site.summary ? <p class="max-w-3xl text-sm leading-6 text-base-content/72">{site.summary}</p> : null}
                        <div class="text-xs text-base-content/55"><span class="break-all">{site.url}</span></div>
                      </div>
                      <div class="inline-flex shrink-0 items-center gap-2 self-start sm:self-center">
                        <a href={linkTo(`/llm-gateway/${site.slug}`)} class="btn btn-primary btn-xs inline-flex h-7 min-h-7 items-center px-3 leading-none" {...gatewaySiteClickAttrs(site)}>{t.llmGateway.viewDetail}</a>
                        <a href={site.outboundUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-xs inline-flex h-7 min-h-7 items-center px-3 leading-none" {...gatewaySiteOpenAttrs(site)}>{t.actions.open}</a>
                      </div>
                    </div>
                  </td>
                  <td data-label={t.labels.score} class="font-mono">{formatPositiveScore(site.siteScore)}</td>
                  <td data-label={t.llmGateway.supportedModels}>
                    {families.length > 0 ? (
                      <div class="flex flex-wrap gap-1.5">
                        {families.map(family => <span class="badge badge-primary badge-outline badge-sm">{family}</span>)}
                      </div>
                    ) : (
                      <span class="text-base-content/35">-</span>
                    )}
                  </td>
                  <td data-label={t.llmGateway.modelCount} class="font-mono">{site.modelCount > 0 ? site.modelCount : '-'}</td>
                  <td data-label={t.llmGateway.paymentMethods}>{paymentMethods.length > 0 ? (
                    <div class="flex flex-wrap gap-1.5">
                      {paymentMethods.map(method => {
                        const icon = paymentIcon(method);
                        const label = paymentLabel(method);
                        return <span class="payment-icon" title={label} aria-label={label}>{icon.src ? <img src={icon.src} alt="" loading="lazy" /> : icon.fallback}</span>;
                      })}
                    </div>
                  ) : <span class="text-base-content/35">-</span>}</td>
                </tr>
              );
            })}
              </tbody>
            </table>
          </div>
          <div class="hidden p-6 text-center text-sm text-base-content/60" data-home-site-empty>{t.llmGateway.filterEmpty}</div>
          {hasMoreSites ? (
            <div class="border-t border-base-300 p-4 text-center">
              <button type="button" class="btn btn-outline btn-sm" data-gateway-load-more="sites">{t.llmGateway.loadMore}</button>
            </div>
          ) : null}
        </div>
      </div>

      <div id="gatewayModelsPanel" role="tabpanel" aria-labelledby="gatewayModelsTab" data-gateway-panel="models" hidden>
        <div class="card-body p-0">
          <div class="gateway-filter-grid grid gap-3 border-b border-base-300 p-4">
            <label class="input input-bordered flex h-11 items-center gap-2">
              <input data-home-model-search type="search" class="grow text-sm" placeholder={t.llmGateway.modelSearchPlaceholder} />
            </label>
          </div>
          <div class="gateway-table-scroll">
            <table class="table table-zebra gateway-home-table gateway-model-table w-full table-fixed align-top border-collapse" data-sortable-table>
              <thead class="bg-base-200 text-sm font-semibold text-base-content">
                <tr>
                  <SortableTableHeader label={t.llmGateway.rank} sortKey="rank" sortType="number" class="w-14" />
                  <SortableTableHeader label={t.labels.model} sortKey="model" class="w-[48%]" />
                  <SortableTableHeader label={t.llmGateway.modelFamily} sortKey="family" class="w-[24%]" />
                  <SortableTableHeader label={t.llmGateway.supportedGatewayCount} sortKey="supportCount" sortType="number" class="w-24" />
                </tr>
              </thead>
              <tbody data-gateway-home-models-list>
                {topModels.map((model, index) => (
                  <tr data-home-model-card data-search={`${model.modelId} ${model.modelFamily}`.toLowerCase()} data-original-order={String(index)} data-sort-rank={String(index + 1)} data-sort-model={model.modelId} data-sort-family={model.modelFamily} data-sort-support-count={String(model.supportSiteCount || 0)}>
                    <td data-label={t.llmGateway.rank} class="font-mono text-sm text-secondary">#{index + 1}</td>
                    <td data-label={t.labels.model}>
                      <a href={modelHref(model.modelId)} class="link link-hover break-words font-mono text-sm font-semibold text-base-content" {...gatewayModelClickAttrs(model)}>{model.modelId}</a>
                    </td>
                    <td data-label={t.llmGateway.modelFamily}>{model.modelFamily}</td>
                    <td data-label={t.llmGateway.supportedGatewayCount} class="font-mono">{model.supportSiteCount}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="hidden p-6 text-center text-sm text-base-content/60" data-home-model-empty>{t.llmGateway.filterEmpty}</div>
          {hasMoreModels ? (
            <div class="border-t border-base-300 p-4 text-center">
              <button type="button" class="btn btn-outline btn-sm" data-gateway-load-more="models">{t.llmGateway.loadMore}</button>
            </div>
          ) : null}
        </div>
      </div>
    </section>
  )}
  <script is:inline slot="scripts" type="application/json" id="gateway-home-config" set:html={JSON.stringify(gatewayHomeConfig)}></script>
  <script is:inline slot="scripts" defer src={sortableTablesScriptUrl}></script>
  <script is:inline slot="scripts" defer src={gatewayHomeScriptUrl}></script>
</PublicPage>
