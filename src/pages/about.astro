---
/*
文件说明: 渲染 CardNav 公开站点的关于页面，介绍项目起点、服务对象和产品定位。
*/
import PublicPage from '../layouts/PublicPage.astro';
import PageContentArticle from '../components/PageContentArticle.astro';
import { loadPageContent } from '../page-content.js';
import { buildSeoContext } from '../seo.js';
import { publicSiteUrl } from '../site.js';
import { applyStaticLocaleLocals } from '../static-locale.js';

export const prerender = true;

applyStaticLocaleLocals(Astro, undefined, '/about');

const content = loadPageContent('about', Astro.locals.locale);
const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/about',
  title: content.title,
  description: content.description,
  imagePath: '/og-cardnav.svg',
  type: 'webpage',
  locale: Astro.locals.locale,
});
---

<PublicPage activeNav="about" showSponsors={false} {...seo}>
  <PageContentArticle content={content} />
</PublicPage>
