---
/*
文件说明: 渲染 CardNav 公开知识库文章详情页，并与知识库首页共享双栏浏览布局。
*/
import PublicPage from '../../layouts/PublicPage.astro';
import KnowledgeBrowser from '../../components/KnowledgeBrowser.astro';
import { findKnowledgeArticle, knowledgeArticles, knowledgeNavItems } from '../../knowledge.js';
import { buildSeoContext } from '../../seo.js';
import { publicSiteUrl } from '../../site.js';

export const prerender = true;

export function getStaticPaths() {
  return knowledgeArticles.map(article => ({
    params: { slug: article.slug },
  }));
}

const slug = Astro.params.slug || '';
const article = findKnowledgeArticle(slug);
if (!article) return Astro.redirect('/knowledge', 302);

const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: `/knowledge/${article.slug}`,
  title: article.title,
  description: article.description,
  imagePath: '/og-cardnav.svg',
  type: 'article',
});
---

<PublicPage activeNav="knowledge" showSponsors={false} {...seo}>
  <KnowledgeBrowser articles={knowledgeArticles} navItems={knowledgeNavItems} currentArticle={article} />
</PublicPage>
