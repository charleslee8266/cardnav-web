---
/*
文件说明: 渲染 CardNav 公开知识库首页，展示文档列表和默认正文。
*/
import PublicPage from '../../layouts/PublicPage.astro';
import KnowledgeBrowser from '../../components/KnowledgeBrowser.astro';
import { defaultKnowledgeArticle, knowledgeArticles, knowledgeNavItems } from '../../knowledge.js';
import { buildSeoContext } from '../../seo.js';
import { publicSiteUrl } from '../../site.js';

if (!defaultKnowledgeArticle) {
  throw new Error('Knowledge articles are required to render /knowledge');
}

const seo = buildSeoContext({
  baseUrl: publicSiteUrl,
  pathname: '/knowledge',
  title: '知识库',
  description: '卡网大全知识库整理 AI 账号购买、商家选择和虚拟商品下单前的判断方法。',
  imagePath: '/og-cardnav.svg',
  type: 'webpage',
});
---

<PublicPage activeNav="knowledge" showSponsors={false} {...seo}>
  <KnowledgeBrowser articles={knowledgeArticles} navItems={knowledgeNavItems} currentArticle={defaultKnowledgeArticle} />
</PublicPage>
