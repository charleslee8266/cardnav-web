<%
  const pageTitleValue = typeof pageTitle === 'string' ? pageTitle : '卡网大全 - AI 大模型账号购买导航';
  const descriptionValue = typeof description === 'string' ? description : '不知道 ChatGPT Plus、Claude、Gemini、Grok 等 AI 账号在哪买？卡网大全聚合大模型账号商家，帮你查找购买入口、库存和价格。';
  const canonicalUrlValue = typeof canonicalUrl === 'string' ? canonicalUrl : 'https://cardnav.xyz/';
  const robotsValue = typeof robots === 'string' ? robots : 'index,follow';
  const ogUrlValue = typeof ogUrl === 'string' ? ogUrl : canonicalUrlValue;
  const ogImageUrlValue = typeof ogImageUrl === 'string' ? ogImageUrl : 'https://cardnav.xyz/og-cardnav.svg';
  const jsonLdValue = typeof jsonLd === 'object' && jsonLd ? jsonLd : { '@context': 'https://schema.org', '@type': 'WebSite' };
  const sourceSites = typeof initialSites !== 'undefined' && Array.isArray(initialSites) ? initialSites : sites;
  const sourceProducts = typeof initialProducts !== 'undefined' && Array.isArray(initialProducts) ? initialProducts : products;
  const renderedSites = sourceSites.map(function(site) {
    return {
      id: site.id || '',
      name: site.name,
      latestProductRefreshedAt: site.latestProductRefreshedAt || null,
      latestProductRefreshTime: site.latestProductRefreshTime || '',
      score: site.score || 0,
    };
  });
  const renderedProducts = sourceProducts.map(function(product) {
    return {
      categoryName: product.categoryName,
      name: product.name,
      priceNumber: typeof product.priceNumber === 'number' ? product.priceNumber : null,
      priceUnit: typeof product.priceUnit === 'string' ? product.priceUnit : null,
      productUrl: product.productUrl,
      stock: product.stock,
      inStock: product.inStock,
      clickCount: product.clickCount || 0,
      siteId: product.siteId || '',
      siteName: product.siteName || '',
      siteLatestProductRefreshedAt: product.siteLatestProductRefreshedAt || null,
      siteLatestProductRefreshTime: product.siteLatestProductRefreshTime || '',
      score: product.score || 0,
    };
  });
  const latestRefreshTimeValue = typeof latestRefreshTime !== 'undefined' ? latestRefreshTime : null;
  const initialProductLimitValue = 100;
  const productStockLabel = function(product) {
    return typeof product.stock === 'number' && product.stock > 0 ? product.stock : (product.inStock ? '有货' : '缺货');
  };
  const renderProductPrice = function(product) {
    if (typeof product.priceNumber === 'number' && typeof product.priceUnit === 'string' && product.priceUnit) {
      return `${product.priceUnit}${String(product.priceNumber)}`;
    }
    return '';
  };
  const searchQueryValue = typeof searchQuery === 'string' ? searchQuery : [siteQuery, productQuery].filter(Boolean).join(' ');
  const totalSiteCountValue = typeof totalSiteCount === 'number' ? totalSiteCount : renderedSites.length;
  const totalProductCountValue = typeof totalProductCount === 'number' ? totalProductCount : renderedProducts.length;
  const popularSearchTermsValue = typeof popularSearchTerms !== 'undefined' && Array.isArray(popularSearchTerms)
    ? popularSearchTerms
        .map(function(term) { return typeof term === 'string' ? term.trim() : ''; })
        .filter(Boolean)
    : [];
  const dashboardJsonValue = JSON.stringify({
    sites: renderedSites,
    products: renderedProducts,
    totalSiteCount: totalSiteCountValue,
    totalProductCount: totalProductCountValue,
    latestRefreshTime: latestRefreshTimeValue,
    initialProductLimit: initialProductLimitValue,
  }).replace(/[<>&\u2028\u2029]/g, function(character) {
    return {
      '<': '\\u003c',
      '>': '\\u003e',
      '&': '\\u0026',
      '\u2028': '\\u2028',
      '\u2029': '\\u2029',
    }[character];
  });
  layout('layouts/public-page.eta', {
    activeNav: 'home',
    pageTitle: pageTitleValue,
    description: descriptionValue,
    canonicalUrl: canonicalUrlValue,
    robots: robotsValue,
    ogUrl: ogUrlValue,
    ogImageUrl: ogImageUrlValue,
    jsonLd: jsonLdValue,
  });
%>
<% block('content', function(){ %>
  <form id="filters" class="content-panel flex flex-col gap-3" method="get">
    <% const summarySiteCount = totalSiteCountValue; %>
    <% const summaryProductCount = totalProductCountValue; %>
    <div class="collection-summary flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-slate-700">
      <span>已收录商家：<span class="public-summary-value"><%= summarySiteCount %></span></span>
      <span>商品：<span class="public-summary-value"><%= summaryProductCount %></span></span>
      <% if (typeof latestRefreshTime !== 'undefined' && latestRefreshTime) { %>
        <span>最近刷新：<%= latestRefreshTime %></span>
      <% } %>
    </div>
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center">
      <input id="searchFilter" name="q" value="<%= searchQueryValue %>" class="control-input" placeholder="搜索商品，多个关键词用空格隔开" autocomplete="off" />
    </div>
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center">
      <div class="flex flex-wrap items-center gap-3">
        <label class="filter-checkbox-label">
          <input id="matchCategoryFilter" name="matchCategory" value="1" type="checkbox" class="control-checkbox cursor-pointer" />
          匹配分类
        </label>
        <label class="filter-checkbox-label">
          <input id="matchMerchantFilter" name="matchMerchant" value="1" type="checkbox" class="control-checkbox cursor-pointer" />
          匹配商家
        </label>
      </div>
      <label class="filter-checkbox-label">
        <input id="showSoldOutFilter" name="showSoldOut" value="1" type="checkbox" class="control-checkbox cursor-pointer" <%= showSoldOut ? 'checked' : '' %> />
        显示无货商品
      </label>
      <label class="filter-checkbox-label">
        <input id="groupByMerchantFilter" name="groupByMerchant" value="1" type="checkbox" class="control-checkbox cursor-pointer" />
        按商家分组
      </label>
      <div class="flex flex-wrap items-center gap-3">
        <span class="text-sm text-slate-700">价格范围</span>
        <div class="flex items-center gap-2">
          <input id="priceMin" name="priceMin" type="number" min="0" step="0.01" inputmode="decimal" class="control-input w-28" placeholder="最小价格" autocomplete="off" />
          <input id="priceMax" name="priceMax" type="number" min="0" step="0.01" inputmode="decimal" class="control-input w-28" placeholder="最大价格" autocomplete="off" />
        </div>
      </div>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-sm font-medium text-slate-700">热门搜索</span>
      <div id="quickTagFilters" class="flex flex-wrap gap-2" aria-label="热门搜索标签">
        <% popularSearchTermsValue.forEach(function(term) { %>
          <% const tagKey = term.trim().toLowerCase().replace(/\s+/g, '-'); %>
          <button type="button" class="quick-tag-filter" data-tag-key="<%= tagKey %>" data-umami-event="quick-search-click" data-umami-event-name="<%= term %>"><%= term %></button>
        <% }) %>
      </div>
    </div>
  </form>

  <div id="emptyState" class="table-shell table-empty-state hidden">没有匹配的商家或商品</div>

  <section id="flatProductView" class="product-table">
    <div class="table-hint-bar">点击表格标题可排序。收藏的商家和商品会始终置顶。</div>
    <table class="flat-product-table">
      <thead class="flat-product-head">
        <tr>
          <th scope="col" class="table-head-index">序号</th>
          <th scope="col" aria-sort="none"><button type="button" class="flat-sort-button" data-sort-key="productName" data-sort-type="text"><span>商品</span><span class="sort-indicator" aria-hidden="true"></span><span class="sort-status">，点击排序</span></button></th>
          <th scope="col" aria-sort="none"><button type="button" class="flat-sort-button" data-sort-key="priceValue" data-sort-type="number"><span>价格</span><span class="sort-indicator" aria-hidden="true"></span><span class="sort-status">，点击排序</span></button></th>
          <th scope="col" aria-sort="none"><button type="button" class="flat-sort-button" data-sort-key="stockValue" data-sort-type="number"><span>库存</span><span class="sort-indicator" aria-hidden="true"></span><span class="sort-status">，点击排序</span></button></th>
          <th scope="col" aria-sort="none"><button type="button" class="flat-sort-button" data-sort-key="categoryName" data-sort-type="text"><span>分类</span><span class="sort-indicator" aria-hidden="true"></span><span class="sort-status">，点击排序</span></button></th>
          <th scope="col" aria-sort="none"><button type="button" class="flat-sort-button" data-sort-key="siteName" data-sort-type="text"><span>商家</span><span class="sort-indicator" aria-hidden="true"></span><span class="sort-status">，点击排序</span></button></th>
        </tr>
      </thead>

      <tbody id="flatProductRows">
      <% let renderedFlatCount = 0; %>
      <% renderedProducts.forEach(function(item){ %>
        <% if (renderedFlatCount >= initialProductLimitValue) { return; } %>
        <% const productTitle = `${item.categoryName}-${item.name}`; %>
        <% const productFavoriteKey = `${item.siteName}#${productTitle}`; %>
        <% const siteFavoriteKey = item.siteId || item.siteName; %>
          <tr class="flat-product-row">
            <th scope="row" class="flat-row-index"></th>
            <td class="flat-product-cell">
              <div class="cell-inline">
                <button type="button" class="favorite-toggle" data-favorite-kind="product" data-favorite-key="<%= productFavoriteKey %>" aria-label="收藏 <%= productTitle %>" aria-pressed="false" title="收藏商品">
                  <span aria-hidden="true">♡</span>
                </button>
                <% if (item.productUrl) { %>
                  <a href="<%= item.productUrl %>" target="_blank" rel="noopener noreferrer" class="product-link" data-umami-event="product-click" data-umami-event-url="<%= item.productUrl %>" data-umami-event-name="<%= productTitle %>" data-product-click-site-id="<%= item.siteId %>" data-product-click-url="<%= item.productUrl %>" data-product-click-category="<%= item.categoryName %>" data-product-click-name="<%= item.name %>"><%= item.name %></a>
                <% } else { %>
                  <span class="product-text"><%= item.name %></span>
                <% } %>
              </div>
            </td>
            <td class="flat-price-cell">
              <%= renderProductPrice(item) %>
            </td>
            <td class="flat-status-cell">
              <span class="<%= item.inStock ? 'stock-badge-in-stock' : 'stock-badge-sold-out' %>"><%= productStockLabel(item) %></span>
            </td>
            <td class="flat-category-cell">
              <%= item.categoryName %>
            </td>
            <td class="flat-merchant-cell">
              <div class="cell-inline">
                <button type="button" class="favorite-toggle" data-favorite-kind="site" data-favorite-key="<%= siteFavoriteKey %>" aria-label="收藏 <%= item.siteName %>" aria-pressed="false" title="收藏商家">
                  <span aria-hidden="true">♡</span>
                </button>
                <span class="merchant-text"><%= item.siteName %></span>
              </div>
            </td>
          </tr>
          <% renderedFlatCount += 1; %>
      <% }) %>
      </tbody>
    </table>
  </section>

  <div id="flatProductProgressiveLoad" class="progressive-load-panel">
    <p id="flatProductLoadSummary" class="progressive-load-summary hidden"></p>
    <button id="flatProductLoadMoreButton" type="button" class="secondary-button hidden">加载更多商品</button>
  </div>

  <section id="merchantGroupedView" class="product-table" hidden>
    <div class="merchant-table-head">
      <div class="merchant-head-index">序号</div>
      <div class="merchant-head-cell">商家</div>
      <div class="merchant-head-cell">商品</div>
    </div>
    <div id="merchantRows"></div>
  </section>

  <script type="application/json" id="dashboard-data"><%~ dashboardJsonValue %></script>
<% }) %>

<% block('scripts', function(){ %>
  <script defer src="/assets/index.js"></script>
<% }) %>
