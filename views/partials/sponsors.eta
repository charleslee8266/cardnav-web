<%
  const telegramGroupUrlValue = typeof telegramGroupUrl === 'string' ? telegramGroupUrl : 'https://t.me/cardnav_xyz_group';
  const sponsorPackyApiUrl = 'https://www.packyapi.com/register?aff=Nulo';
  const sponsorRightCodeUrl = 'https://www.right.codes/register?aff=7e525e44';
  const sponsorPrimaryUrl = 'https://my.racknerd.com/aff.php?aff=20079&pid=952';
  const sponsorPlan2c2gUrl = 'https://my.racknerd.com/aff.php?aff=20079&pid=953';
  const sponsorPlan3c4gUrl = 'https://my.racknerd.com/aff.php?aff=20079&pid=954';
  const sponsorPlan6c6gUrl = 'https://my.racknerd.com/aff.php?aff=20079&pid=955';
  const sponsorPlan7c8gUrl = 'https://my.racknerd.com/aff.php?aff=20079&pid=956';
%>
<section class="rounded border border-slate-200 bg-white p-3 text-sm">
  <div class="mb-2 flex items-center gap-3">
    <h2 class="text-sm font-semibold text-slate-800">赞助商列表</h2>
    <a href="<%= telegramGroupUrlValue %>" target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-blue-700 hover:text-blue-800">成为赞助商</a>
  </div>
  <div class="flex flex-wrap gap-3">
    <article class="sponsor-card flex w-full max-w-[344px] flex-col rounded border border-slate-200 bg-slate-50">
      <a href="<%= sponsorPackyApiUrl %>" target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url="<%= sponsorPackyApiUrl %>" class="group flex flex-1 flex-col gap-2 p-3">
        <span class="flex h-[100px] w-full items-center justify-center overflow-hidden rounded bg-white px-4">
          <img src="https://www.packyapi.com/logo-full.svg" alt="PackyAPI AI API 聚合平台赞助商标志" width="320" height="73" loading="lazy" class="h-auto w-full max-w-[320px] object-contain text-slate-950" />
        </span>
        <span class="block text-center text-sm font-semibold leading-5 text-slate-900 underline-offset-2 group-hover:underline">
          PackyAPI 老牌 AI API 中转站
        </span>
        <span class="block text-center text-xs leading-5 text-slate-600">一站式接入 Claude、GPT、Gemini 等主流 AI 服务，可提供发票。</span>
      </a>
    </article>
    <article class="sponsor-card flex w-full max-w-[344px] flex-col rounded border border-slate-200 bg-slate-50">
      <a href="<%= sponsorRightCodeUrl %>" target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url="<%= sponsorRightCodeUrl %>" class="group flex flex-1 flex-col gap-2 p-3">
        <span class="flex h-[100px] w-full items-center justify-center overflow-hidden rounded bg-white">
          <img src="/rightcode.png" alt="RightCode 赞助商标志" width="1150" height="332" loading="lazy" class="h-auto w-full max-w-[320px] object-contain text-slate-950" />
        </span>
        <span class="block text-center text-sm font-semibold leading-5 text-slate-900 underline-offset-2 group-hover:underline">
          RightCode 企业级 AI Agent 分发平台
        </span>
        <span class="block text-center text-xs leading-5 text-slate-600">专注于编程开发，支持Codex、Claude、DeepSeek等多种模型。</span>
      </a>
    </article>
    <article class="sponsor-card flex w-full max-w-[344px] flex-col rounded border border-slate-200 bg-slate-50">
      <a href="<%= sponsorPrimaryUrl %>" target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url="<%= sponsorPrimaryUrl %>" class="group flex flex-col gap-1 p-3 pb-1.5">
        <span class="flex w-full items-center justify-center overflow-hidden rounded bg-white">
          <img src="https://racknerd.com/banners/320x100.gif" alt="RackNerd 云主机赞助商横幅" width="320" height="100" loading="lazy" class="h-auto w-full max-w-[320px] object-contain" />
        </span>
        <span class="block text-center">
          <span class="text-sm font-semibold text-slate-900">RackNerd云主机</span>
          <span class="ml-1 text-sm font-semibold leading-5 text-red-600 underline-offset-2 group-hover:underline">1C1G 仅需 $21.99/年</span>
        </span>
      </a>
      <div class="grid grid-cols-2 gap-y-0 pb-2 text-sm leading-5 text-slate-600">
        <a href="<%= sponsorPlan2c2gUrl %>" target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url="<%= sponsorPlan2c2gUrl %>" class="block px-3 py-0.5 text-center hover:text-red-700 hover:underline">2C2G $35.99/年</a>
        <a href="<%= sponsorPlan3c4gUrl %>" target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url="<%= sponsorPlan3c4gUrl %>" class="block px-3 py-0.5 text-center hover:text-red-700 hover:underline">3C4G $59.99/年</a>
        <a href="<%= sponsorPlan6c6gUrl %>" target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url="<%= sponsorPlan6c6gUrl %>" class="block px-3 py-0.5 text-center hover:text-red-700 hover:underline">6C6G $89.99/年</a>
        <a href="<%= sponsorPlan7c8gUrl %>" target="_blank" rel="nofollow sponsored noopener noreferrer" data-umami-event="sponsor-click" data-umami-event-url="<%= sponsorPlan7c8gUrl %>" class="block px-3 py-0.5 text-center hover:text-red-700 hover:underline">7C8G $119.99/年</a>
      </div>
    </article>
  </div>
</section>
